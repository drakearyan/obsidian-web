---
interface Props {
  badge?: string;
  title: string;
  titleAccent?: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
  /** Override the default secondary CTA (defaults to portfolio link). */
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  badge = 'EST. 2026 · FAIRFAX, VA',
  title,
  titleAccent,
  subtitle,
  ctaText = 'Start a Project',
  ctaHref = '/contact',
  secondaryText = 'See our work',
  secondaryHref = '/portfolio',
} = Astro.props;

const year = new Date().getFullYear();

// Split title + accent into words for the staggered reveal. Each word
// becomes a <span> with a CSS variable that drives its animation delay.
const title_words = title.split(/\s+/).filter(Boolean);
const accent_words = titleAccent ? titleAccent.split(/\s+/).filter(Boolean) : [];
---

<section class="hero" data-cursor-spotlight>
  <div class="hero-spotlight" aria-hidden="true"></div>
  <div class="hero-grid">
    <!-- Top-left: meta info -->
    <div class="hero-meta hero-meta--tl">
      <div class="meta-block">
        <span class="meta-label">[01]</span>
        <span class="meta-text">{badge}</span>
      </div>
    </div>

    <!-- Center: giant editorial headline. Each word renders as an
         inline-block span so it can be staggered into view via
         animation-delay derived from --word-i. Honoring text-wrap:
         balance keeps line-breaks behaving as before. -->
    <div class="hero-title-wrap">
      <h1 class="hero-title">
        {title_words.map((w, i) => (
          <span class="hero-word" style={`--word-i: ${i}`}>{w}{i < title_words.length - 1 ? ' ' : ''}</span>
        ))}
        {accent_words.length > 0 && (
          <em class="hero-accent">
            {accent_words.map((w, i) => (
              <span class="hero-word" style={`--word-i: ${i + title_words.length}`}>{w}{i < accent_words.length - 1 ? ' ' : ''}</span>
            ))}
          </em>
        )}
      </h1>
    </div>

    <!-- Bottom-left: description + CTAs -->
    <div class="hero-meta hero-meta--bl">
      <p class="hero-sub" data-reveal>{subtitle}</p>
      <div class="hero-cta" data-reveal>
        <a href={ctaHref} class="btn-primary">
          {ctaText}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href={secondaryHref} class="arrow-link">
          {secondaryText}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom-right: scroll indicator -->
    <div class="hero-meta hero-meta--br">
      <div class="scroll-indicator">
        <span class="meta-label">scroll</span>
        <div class="scroll-line"><div class="scroll-line-fill"></div></div>
      </div>
    </div>
  </div>

  <!-- Ticker at very bottom.
       Two identical ticker-group nodes. Each group ends with its own
       trailing dot so when translateX(-50%) wraps the track, the next
       group lines up exactly where the previous one started — no
       visible reset at the "E-commerce" seam. -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <div class="ticker-group">
        <span>Restaurants</span><span>●</span>
        <span>Legal</span><span>●</span>
        <span>Healthcare</span><span>●</span>
        <span>Fitness</span><span>●</span>
        <span>Trades</span><span>●</span>
        <span>E-commerce</span><span>●</span>
      </div>
      <div class="ticker-group" aria-hidden="true">
        <span>Restaurants</span><span>●</span>
        <span>Legal</span><span>●</span>
        <span>Healthcare</span><span>●</span>
        <span>Fitness</span><span>●</span>
        <span>Trades</span><span>●</span>
        <span>E-commerce</span><span>●</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    padding: calc(var(--nav-height) + 1rem) 2rem 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  /* Cursor-following spotlight — soft ember radial that brightens
     a 360px disc under the visitor's cursor. CSS variables update
     in real time from the data-cursor-spotlight script; absent JS
     the gradient sits in the upper-left corner harmlessly. */
  .hero-spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      360px circle at var(--cursor-x, 50%) var(--cursor-y, 50%),
      rgba(233, 162, 70, 0.08),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 0;
  }

  .hero[data-cursor-spotlight]:hover .hero-spotlight {
    opacity: 1;
  }

  /* Pointer-based devices only — hide on touch */
  @media (hover: none) {
    .hero-spotlight { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-spotlight { display: none; }
  }

  /* Ensure content above the spotlight */
  .hero-grid { position: relative; z-index: 1; }
  .ticker { position: relative; z-index: 1; }

  .hero-grid {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    grid-template-areas:
      "tl tl"
      "title title"
      "bl br";
    gap: 2rem 3rem;
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "tl"
        "title"
        "bl"
        "br";
      gap: 1rem;
    }
  }

  .hero-meta--tl { grid-area: tl; }
  .hero-meta--bl { grid-area: bl; align-self: end; max-width: 460px; }
  .hero-meta--br { grid-area: br; justify-self: end; align-self: end; }

  @media (max-width: 768px) {
    .hero-meta--br { justify-self: start; }
  }

  .meta-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .meta-label {
    color: var(--ember);
    font-weight: 500;
  }

  .meta-text {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* The giant title */
  .hero-title-wrap {
    grid-area: title;
    align-self: center;
    display: flex;
    align-items: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 13vw, 12rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.045em;
    color: var(--text);
    text-wrap: balance;
  }

  .hero-accent {
    display: block;
    font-style: italic;
    color: var(--ember);
    font-weight: 400;
  }

  /* Per-word stagger reveal — runs once on page load. inline-block
     so translate works on each word; animation-delay derived from
     --word-i so words enter in document order. Overflow hidden on
     the parent line wrapper would cleave the rise — kept off since
     letters with descenders (y, g) read better without clipping. */
  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(40%) rotate(2deg);
    animation: heroWordIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: calc(0.08s + var(--word-i) * 0.09s);
    will-change: opacity, transform;
  }

  @keyframes heroWordIn {
    to {
      opacity: 1;
      transform: translateY(0) rotate(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word { animation: none; opacity: 1; transform: none; }
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 1.5rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Scroll indicator */
  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(232, 220, 196, 0.15);
    overflow: hidden;
    position: relative;
  }

  .scroll-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--ember);
    animation: scroll-down 2s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* Ticker */
  .ticker {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    overflow: hidden;
    margin: 0 -2rem;
    background: var(--surface);
  }

  .ticker-track {
    display: flex;
    /* NO gap here — the seam between the two groups must be exactly
       the same as the seam between items inside a group. Gap on the
       track would add one extra 3rem only at the wrap point, causing
       the visible jump Drake described. */
    white-space: nowrap;
    animation: ticker 40s linear infinite;
    /* GPU layer hint for smooth sub-pixel scroll */
    will-change: transform;
  }

  .ticker-group {
    display: flex;
    gap: 3rem;
    /* Trailing padding = same as inter-item gap so the last bullet
       of group 1 is 3rem from the first word of group 2, matching
       every other item-to-item spacing exactly. */
    padding-right: 3rem;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--muted);
  }

  /* Style the bullet dots — every 2nd child in each group. */
  .ticker-group span:nth-child(even) {
    color: var(--ember);
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.8rem;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* Pause animation for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }
</style>

<script>
  // Cursor spotlight tracker — updates CSS variables on the hero
  // element so the radial gradient follows the pointer. Throttled
  // via requestAnimationFrame to one update per paint. Skips when
  // prefers-reduced-motion or no pointer device.
  (function initCursorSpotlight() {
    if (typeof window === 'undefined') return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const has_pointer = window.matchMedia('(hover: hover)').matches;
    if (reduce || !has_pointer) return;

    const targets = document.querySelectorAll<HTMLElement>('[data-cursor-spotlight]');
    if (!targets.length) return;

    targets.forEach((el) => {
      let ticking = false;
      let last_x = 0;
      let last_y = 0;
      el.addEventListener('pointermove', (e) => {
        last_x = e.clientX;
        last_y = e.clientY;
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          const rect = el.getBoundingClientRect();
          const x = ((last_x - rect.left) / rect.width) * 100;
          const y = ((last_y - rect.top) / rect.height) * 100;
          el.style.setProperty('--cursor-x', `${x.toFixed(1)}%`);
          el.style.setProperty('--cursor-y', `${y.toFixed(1)}%`);
        });
      });
    });
  })();
</script>
