---
interface Props {
  badge?: string;
  title: string;
  titleAccent?: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  badge = 'EST. 2026 · LYNCHBURG, VA',
  title,
  titleAccent,
  subtitle,
  ctaText = 'Start a Project',
  ctaHref = '/contact',
} = Astro.props;

const year = new Date().getFullYear();
---

<section class="hero">
  <div class="hero-grid">
    <!-- Top-left: meta info -->
    <div class="hero-meta hero-meta--tl">
      <div class="meta-block">
        <span class="meta-label">[01]</span>
        <span class="meta-text">{badge}</span>
      </div>
    </div>

    <!-- Top-right: work counter -->
    <div class="hero-meta hero-meta--tr">
      <div class="meta-block meta-block--right">
        <span class="meta-label">currently</span>
        <span class="meta-text"><span class="dot-pulse"></span> accepting Q{Math.ceil((new Date().getMonth() + 1) / 3)} {year} projects</span>
      </div>
    </div>

    <!-- Center: giant editorial headline -->
    <div class="hero-title-wrap">
      <h1 class="hero-title" data-reveal>
        {title}
        {titleAccent && <em class="hero-accent">{titleAccent}</em>}
      </h1>
    </div>

    <!-- Bottom-left: description + CTAs -->
    <div class="hero-meta hero-meta--bl">
      <p class="hero-sub" data-reveal>{subtitle}</p>
      <div class="hero-cta" data-reveal>
        <a href={ctaHref} class="btn-primary">
          {ctaText}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="/portfolio" class="arrow-link">
          See our work
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom-right: scroll indicator -->
    <div class="hero-meta hero-meta--br">
      <div class="scroll-indicator">
        <span class="meta-label">scroll</span>
        <div class="scroll-line"><div class="scroll-line-fill"></div></div>
      </div>
    </div>
  </div>

  <!-- Ticker at very bottom -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>Restaurants</span><span>●</span>
      <span>Legal</span><span>●</span>
      <span>Healthcare</span><span>●</span>
      <span>Fitness</span><span>●</span>
      <span>Trades</span><span>●</span>
      <span>E-commerce</span><span>●</span>
      <span>Restaurants</span><span>●</span>
      <span>Legal</span><span>●</span>
      <span>Healthcare</span><span>●</span>
      <span>Fitness</span><span>●</span>
      <span>Trades</span><span>●</span>
      <span>E-commerce</span><span>●</span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    padding: calc(var(--nav-height) + 1rem) 2rem 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
  }

  .hero-grid {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto 1fr auto;
    grid-template-areas:
      "tl tr"
      "title title"
      "bl br";
    gap: 2rem 3rem;
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "tl"
        "title"
        "bl"
        "br";
      gap: 1.5rem;
    }
  }

  .hero-meta--tl { grid-area: tl; }
  .hero-meta--tr { grid-area: tr; justify-self: end; }
  .hero-meta--bl { grid-area: bl; align-self: end; max-width: 460px; }
  .hero-meta--br { grid-area: br; justify-self: end; align-self: end; }

  @media (max-width: 768px) {
    .hero-meta--tr, .hero-meta--br { justify-self: start; }
  }

  .meta-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .meta-label {
    color: var(--ember);
    font-weight: 500;
  }

  .meta-text {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .dot-pulse {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse-dot 2s ease-in-out infinite;
    box-shadow: 0 0 8px #4ade80;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* The giant title */
  .hero-title-wrap {
    grid-area: title;
    align-self: center;
    display: flex;
    align-items: center;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 13vw, 12rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.045em;
    color: var(--text);
    text-wrap: balance;
  }

  .hero-accent {
    display: block;
    font-style: italic;
    color: var(--ember);
    font-weight: 400;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 1.5rem;
  }

  .hero-cta {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Scroll indicator */
  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: rgba(232, 220, 196, 0.15);
    overflow: hidden;
    position: relative;
  }

  .scroll-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--ember);
    animation: scroll-down 2s ease-in-out infinite;
  }

  @keyframes scroll-down {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }

  /* Ticker */
  .ticker {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    overflow: hidden;
    margin: 0 -2rem;
    background: var(--surface);
  }

  .ticker-track {
    display: flex;
    gap: 3rem;
    white-space: nowrap;
    animation: ticker 40s linear infinite;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--muted);
  }

  .ticker-track span:nth-child(even) {
    color: var(--ember);
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.8rem;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
</style>
