---
import { nav_links } from '../data/site';

const current_path = Astro.url.pathname;
---

<nav id="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" aria-label="Obsidian Web Co. home" class="nav-mark">
      <svg width="28" height="28" viewBox="0 0 80 80" fill="none" aria-hidden="true">
        <polygon points="40,4 62,24 52,76 28,76 18,24" fill="var(--ember)" opacity="0.9"/>
        <polygon points="40,4 62,24 40,32 18,24" fill="var(--text)" opacity="0.3"/>
        <line x1="40" y1="4" x2="40" y2="32" stroke="var(--text)" stroke-width="0.6" opacity="0.4"/>
      </svg>
      <span class="nav-wordmark">
        <span class="nav-name">Obsidian</span>
        <span class="nav-sub">Web Co.</span>
      </span>
    </a>

    <button
      class="nav-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <line x1="3" y1="8" x2="21" y2="8"/>
        <line x1="3" y1="16" x2="21" y2="16"/>
      </svg>
    </button>

    <ul class="nav-links" id="nav-links">
      {nav_links.filter(l => l.href !== '/').map((link) => {
        const is_active = current_path.startsWith(link.href);
        return (
          <li>
            <a
              href={link.href}
              class={is_active ? 'active' : ''}
              aria-current={is_active ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
      <li>
        <a href="/contact" class="btn-primary nav-cta">Start a Project</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav-mark {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    color: var(--text);
  }

  .nav-mark:hover { text-decoration: none; }

  .nav-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .nav-name {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .nav-sub {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 2px;
  }

  @media (max-width: 500px) {
    .nav-sub { display: none; }
  }
</style>
