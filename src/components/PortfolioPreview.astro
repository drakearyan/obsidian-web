---
import { case_studies } from '../data/portfolio';
const featured = case_studies.filter((c) => c.featured).slice(0, 3);

const palettes: Record<string, { bg: string; fg: string; name: string }> = {
  restaurant: { bg: '#D4481E', fg: '#F5ECD9', name: 'cinnabar' },
  legal: { bg: '#1E3A52', fg: '#E8DCC4', name: 'ink' },
  fitness: { bg: '#3D6B5C', fg: '#F5ECD9', name: 'moss' },
  healthcare: { bg: '#6B4E7A', fg: '#F5ECD9', name: 'iris' },
  trades: { bg: '#8B4513', fg: '#F5ECD9', name: 'copper' },
  ecommerce: { bg: '#2C3E50', fg: '#E9A246', name: 'slate' },
};
---

<section class="work-index">
  <div class="container">
    <div class="work-head">
      <span class="section-label">[03] / selected work</span>
      <h2 class="work-title">Real sites. <em class="serif-accent">Real receipts.</em></h2>
    </div>

    <div class="work-list">
      {featured.map((cs, i) => {
        const p = palettes[cs.industrySlug] || { bg: '#1a1a1a', fg: '#fff', name: 'void' };
        return (
          <a href="/portfolio" class="work-item">
            <div class="work-num">{String(i + 1).padStart(2, '0')}</div>

            <div class="work-thumb" style={`background: ${p.bg};`}>
              <div class="thumb-meta" style={`color: ${p.fg};`}>
                <span>#{p.name}</span>
                <span>{cs.industry}</span>
              </div>
              <div class="thumb-label" style={`color: ${p.fg};`}>
                {cs.client.split(' ').map((w) => w[0]).join('').slice(0, 3)}
              </div>
            </div>

            <div class="work-body">
              <h3 class="work-name">{cs.client}</h3>
              <p class="work-desc">{cs.summary}</p>

              <div class="work-metrics">
                {cs.results.slice(0, 2).map((r) => (
                  <div class="work-metric">
                    <span class="metric-val">{r.value}</span>
                    <span class="metric-key">{r.metric}</span>
                  </div>
                ))}
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <div class="work-footer">
      <a href="/portfolio" class="arrow-link">
        View all projects
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .work-index { padding: 8rem 0; border-top: 1px solid var(--border); }

  .work-head {
    margin-bottom: 5rem;
  }

  .work-title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-top: 0.5rem;
  }

  .work-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .work-item {
    display: grid;
    grid-template-columns: 80px 1fr 1.2fr;
    gap: 3rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    transition: padding 0.3s ease;
  }

  .work-item:hover {
    padding-left: 1rem;
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .work-item {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  .work-num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--ember);
    padding-top: 0.5rem;
  }

  .work-thumb {
    aspect-ratio: 4 / 3;
    min-height: 200px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .work-item:hover .work-thumb {
    transform: scale(1.02);
  }

  .thumb-meta {
    position: absolute;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: lowercase;
    letter-spacing: 0.05em;
    opacity: 0.75;
  }

  .thumb-label {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.04em;
    opacity: 0.95;
  }

  .work-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: 0.5rem;
  }

  .work-name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.1;
    color: var(--text);
  }

  .work-desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.55;
  }

  .work-metrics {
    display: flex;
    gap: 3rem;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .work-metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metric-val {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--ember);
    line-height: 1;
  }

  .metric-key {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .work-footer {
    margin-top: 3rem;
    display: flex;
    justify-content: flex-end;
  }
</style>
