---
/**
 * Shared shell for authenticated dashboard pages. Sidebar + content area.
 * Styled inline to match the editorial palette until this is migrated into
 * the main site (then it'll pick up the site's global.css tokens).
 */
interface Props {
  title: string;
  active: 'overview' | 'pipeline' | 'leads' | 'agents' | 'security';
}
const { title, active } = Astro.props;

const nav = [
  { href: '/dashboard', key: 'overview', label: '№ 01 · Overview' },
  { href: '/dashboard/pipeline', key: 'pipeline', label: '№ 02 · Pipeline' },
  { href: '/dashboard/leads', key: 'leads', label: '№ 03 · Leads' },
  { href: '/dashboard/agents', key: 'agents', label: '№ 04 · Agents' },
  { href: '/dashboard/security', key: 'security', label: '№ 05 · Security' },
] as const;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · Obsidian Dashboard</title>
  <style is:global>
    :root {
      --bg: #0b0a08;
      --bg2: #111009;
      --fg: #efe8dd;
      --muted: #7d7568;
      --ember: #e9a246;
      --flame: #c4482d;
      --jade: #6faf88;
      --line: rgba(239, 232, 221, 0.12);
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg); }
    body { font-family: 'Instrument Sans', ui-sans-serif, system-ui, sans-serif; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    .shell { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
    .side { border-right: 1px solid var(--line); padding: 2rem 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
    .brand { font-family: 'Instrument Serif', serif; font-style: italic; font-size: 1.5rem; }
    .sub { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--muted); }
    nav ul { list-style: none; padding: 0; margin: 1rem 0 0; display: flex; flex-direction: column; gap: 0.25rem; }
    nav a {
      display: block;
      padding: 0.6rem 0.75rem;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      border-left: 2px solid transparent;
      transition: color 120ms ease, border-color 120ms ease, background 120ms ease;
    }
    nav a:hover { color: var(--fg); background: rgba(233, 162, 70, 0.04); }
    nav a.active { color: var(--ember); border-left-color: var(--ember); }
    .side-foot { margin-top: auto; font-size: 0.7rem; color: var(--muted); display: flex; flex-direction: column; gap: 0.5rem; }
    main { padding: 2.5rem 3rem; max-width: 1400px; }
    main h1 { font-family: 'Instrument Serif', serif; font-size: 2.5rem; font-weight: 400; margin: 0 0 0.25rem; letter-spacing: -0.02em; }
    main .eyebrow { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--muted); margin: 0 0 1.5rem; }
    .grid { display: grid; gap: 1px; background: var(--line); margin-top: 2rem; }
    .grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
    .grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
    .tile { background: var(--bg); padding: 1.5rem; }
    .tile .label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--muted); margin-bottom: 0.5rem; }
    .tile .val { font-family: 'Instrument Serif', serif; font-size: 2rem; letter-spacing: -0.01em; }
    .tile .delta { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.8rem; color: var(--jade); }
    table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; }
    th, td { text-align: left; padding: 0.75rem 0.5rem; border-bottom: 1px solid var(--line); font-size: 0.85rem; }
    th { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--muted); font-weight: 500; }
    .pill { display: inline-block; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; padding: 0.15rem 0.5rem; border: 1px solid var(--line); }
    .pill.won { color: var(--jade); border-color: rgba(111, 175, 136, 0.4); }
    .pill.lost { color: var(--flame); border-color: rgba(196, 72, 45, 0.4); }
    .pill.warm { color: var(--ember); border-color: rgba(233, 162, 70, 0.4); }
    .empty {
      padding: 2rem;
      border: 1px dashed var(--line);
      text-align: center;
      color: var(--muted);
      font-size: 0.85rem;
      margin-top: 1.5rem;
    }
    form.logout button {
      background: none; border: 1px solid var(--line); color: var(--muted);
      padding: 0.5rem 0.75rem; font-size: 0.65rem; text-transform: uppercase;
      letter-spacing: 0.15em; cursor: pointer; font-family: inherit;
      transition: color 120ms, border-color 120ms;
    }
    form.logout button:hover { color: var(--flame); border-color: rgba(196, 72, 45, 0.4); }
  </style>
</head>
<body>
  <div class="shell">
    <aside class="side">
      <div>
        <div class="brand">Obsidian</div>
        <div class="sub">Dashboard</div>
      </div>
      <nav>
        <ul>
          {nav.map((item) => (
            <li>
              <a href={item.href} class={active === item.key ? 'active' : ''}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <div class="side-foot">
        <form class="logout" action="/dashboard/logout" method="POST">
          <button type="submit">Sign out</button>
        </form>
        <div>v0.1 · staged</div>
      </div>
    </aside>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>
