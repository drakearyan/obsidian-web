---
import { site } from '../data/site';
import NewsletterSignup from './NewsletterSignup.astro';
import LighthouseBadge from './LighthouseBadge.astro';

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <svg width="36" height="36" viewBox="0 0 80 80" fill="none" aria-hidden="true">
          <polygon points="40,4 62,24 52,76 28,76 18,24" fill="var(--ember)" opacity="0.9"/>
          <polygon points="40,4 62,24 40,32 18,24" fill="var(--text)" opacity="0.3"/>
        </svg>
        <div class="footer-wordmark">
          <div class="footer-name">Obsidian</div>
          <div class="footer-sub">Web Co. · est. {site.founded}</div>
        </div>
      </div>

      <div class="footer-newsletter">
        <p class="footer-desc">
          A boutique web design studio based in {site.location.city}, {site.location.state}. Built by <em class="serif-accent">one developer obsessed with craft.</em>
        </p>
        <NewsletterSignup
          variant="inline"
          heading=""
          subheading="One essay a month on what makes small-business websites actually work."
          ctaLabel="Subscribe"
          tag="newsletter"
          placeholder="you@business.com"
        />
      </div>
    </div>

    <div class="footer-grid">
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/services#starter">Starter Site</a></li>
          <li><a href="/services#professional">Professional Site</a></li>
          <li><a href="/services#premium">Premium / E-Commerce</a></li>
          <li><a href="/calculator">Pricing Calculator</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Studio</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/portfolio">Portfolio</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/roadmap">Roadmap</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/resources">All resources</a></li>
          <li><a href="/audit">Free Website Audit</a></li>
          <li><a href="/quiz">Tier Quiz</a></li>
          <li><a href="/calculator">Pricing Calculator</a></li>
          <li><a href="/resources/glossary">Glossary</a></li>
          <li><a href="/resources/tech-stack">Tech Stack</a></li>
          <li><a href="/resources/proposal-example">Proposal example</a></li>
          <li><a href="/resources/what-ill-ask">Kickoff questions</a></li>
          <li><a href="/refer">Referral Program</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          {site.phone && <li><a href={`tel:${site.phone}`}>{site.phone}</a></li>}
          <li>{site.location.city}, {site.location.state}</li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacy">Privacy</a></li>
          <li><a href="/terms">Terms</a></li>
        </ul>
      </div>
    </div>

    <!-- Industry + service-area landing pages, grouped so the main
         nav grid stays clean and these pages still get crawlable,
         clickable exposure from every page on the site. -->
    <div class="footer-discover">
      <div class="footer-discover-col">
        <h4>By Industry</h4>
        <ul>
          <li><a href="/web-design-restaurants">Restaurants</a></li>
          <li><a href="/web-design-dental">Dental Practices</a></li>
          <li><a href="/web-design-legal">Law Firms</a></li>
          <li><a href="/web-design-ecommerce">E-commerce</a></li>
        </ul>
      </div>

      <div class="footer-discover-col">
        <h4>Service Areas</h4>
        <ul>
          <li><a href="/web-design-northern-virginia">Northern Virginia</a></li>
          <li><a href="/web-design-annandale">Annandale, VA</a></li>
          <li><a href="/web-design-falls-church">Falls Church, VA</a></li>
          <li><a href="/web-design-fairfax">Fairfax, VA</a></li>
          <li><a href="/web-design-lynchburg">Lynchburg, VA</a></li>
          <li><a href="/web-design-forest-va">Forest, VA</a></li>
          <li><a href="/web-design-madison-heights">Madison Heights, VA</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-proof">
      <LighthouseBadge />
      <p class="footer-proof-copy">
        Every Obsidian site targets these scores at launch. Click the badge to run a live audit on this page yourself.
      </p>
    </div>

    <div class="footer-bottom">
      <span>© {year} Obsidian Web Co. All rights reserved.</span>
      <span>— Forged in Northern Virginia —</span>
    </div>
  </div>
</footer>

<style>
  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: 2rem; padding-bottom: 2.5rem; }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .footer-sub {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 4px;
  }

  .footer-desc {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.35;
    color: var(--text);
    letter-spacing: -0.01em;
    max-width: 500px;
  }

  /* Footer link grid. Default to 6 columns to match the live layout
     (industry + service-area + about + legal + social + extras).
     Two breakpoints collapse the grid for tablet and mobile. */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (max-width: 1100px) {
    .footer-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 700px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }

  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Industry + service-area link lists — editorial, denser than main
     footer nav so they don't pull focus but stay crawlable. */
  .footer-discover {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    padding: 2rem 0;
    margin-bottom: 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  @media (max-width: 600px) {
    .footer-discover { grid-template-columns: 1fr; gap: 1.5rem; }
  }

  .footer-discover-col h4 {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted);
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .footer-discover-col ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    padding: 0;
    margin: 0;
  }

  .footer-discover-col a {
    color: var(--muted);
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .footer-discover-col a:hover {
    color: var(--ember);
    text-decoration: none;
  }

  /* Lighthouse proof block — anchors the page with a concrete performance
     claim. Sits between the industry/service-area strip and copyright. */
  .footer-proof {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    align-items: center;
    padding: 2rem 0;
    margin-bottom: 2rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  @media (max-width: 640px) {
    .footer-proof { grid-template-columns: 1fr; gap: 1rem; }
  }
  .footer-proof-copy {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 480px;
  }

</style>
