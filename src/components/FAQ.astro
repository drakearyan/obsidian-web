---
import { faqs } from '../data/faq';
---

<section class="faqs">
  <div class="container">
    <div class="faqs-head" data-reveal>
      <span class="section-label">[06] / common questions</span>
      <h2 class="faqs-title">You're probably <em class="serif-accent">wondering.</em></h2>
    </div>

    <div class="faqs-list">
      {faqs.map((faq, i) => (
        <div class="accordion-item faq-item">
          <button
            type="button"
            class="accordion-trigger faq-trigger"
            aria-expanded="false"
            aria-controls={`faq-panel-${i}`}
            id={`faq-trigger-${i}`}
          >
            <span class="faq-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="faq-q">{faq.question}</span>
            <span class="accordion-chevron faq-plus" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </span>
          </button>
          <div id={`faq-panel-${i}`} class="accordion-panel" role="region" aria-labelledby={`faq-trigger-${i}`}>
            <div class="faq-a">
              <p>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faqs { padding: 8rem 0; border-top: 1px solid var(--border); }

  .faqs-head { margin-bottom: 4rem; }

  .faqs-title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-top: 0.5rem;
  }

  .faqs-list {
    border-top: 1px solid var(--border);
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
    background: transparent;
    border-left: none;
    border-right: none;
    border-radius: 0;
    overflow: hidden;
  }

  .faq-item.is-open .faq-plus svg {
    transform: rotate(45deg);
  }

  .faq-plus svg {
    transition: transform var(--accordion-duration) var(--accordion-ease);
    color: var(--ember);
  }

  .faq-trigger {
    width: 100%;
    padding: 1.75rem 0;
    background: transparent;
    border: none;
    color: var(--text);
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    text-align: left;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2vw, 1.5rem);
    line-height: 1.2;
    transition: color 0.2s ease;
  }

  .faq-trigger:hover { color: var(--ember); }

  .faq-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-2);
    letter-spacing: 0.1em;
  }

  .faq-a {
    padding: 0 0 1.75rem 3.25rem;
    max-width: 780px;
  }

  .faq-a p {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.65;
  }
</style>
