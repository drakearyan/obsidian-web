---
/*
  CalendlyAvailability
  ─────────────────────────────────────────────────────────────
  Fetches the next 3 open discovery-call slots from /api/calendly-
  availability (which proxies Calendly v2 when env vars are set).
  Shows the slots as ember chips that link straight to the Calendly
  booking flow. Falls back to a plain "View available times" link
  when no API credentials are configured — so the UI is useful
  even on a fresh checkout.
*/
import { site } from '../data/site';
---

<section class="cal-avail" data-cal-avail data-fallback={site.calendly}>
  <div class="container">
    <div class="cal-head">
      <span class="section-label">[ ◴ ] / availability</span>
      <h2 class="cal-title">Next open <em class="serif-accent">discovery calls.</em></h2>
      <p class="cal-lead">
        Pick a slot, confirm, done. Drake answers your scheduling email himself; no account manager in between.
      </p>
    </div>

    <div class="cal-slots" data-cal-slots>
      <a class="cal-slot cal-slot--fallback" href={site.calendly}>
        <span class="cal-slot-label">View available times</span>
        <span class="cal-slot-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .cal-avail {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .cal-head { max-width: 760px; margin-bottom: 2rem; }

  .cal-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 1rem 0 1rem;
  }

  .cal-lead {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 560px;
  }

  .cal-slots {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cal-slot {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1.1rem;
    background: var(--surface);
    border: 1px solid rgba(233, 162, 70, 0.35);
    border-radius: var(--radius-pill);
    text-decoration: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  .cal-slot:hover {
    background: rgba(233, 162, 70, 0.08);
    border-color: var(--ember);
    transform: translateY(-1px);
    text-decoration: none;
  }

  .cal-slot-day {
    font-family: var(--font-mono);
    color: var(--ember);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
  }

  .cal-slot-time {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--text);
  }

  .cal-slot-arrow { color: var(--ember); margin-left: 0.25rem; }

  .cal-slot-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>

<script>
  (function initCalendlyAvailability() {
    if (typeof window === 'undefined') return;
    const wrap = document.querySelector<HTMLElement>('[data-cal-avail]');
    const slots_el = document.querySelector<HTMLElement>('[data-cal-slots]');
    if (!wrap || !slots_el) return;

    const fallback_url = wrap.dataset.fallback || '#';

    const format_slot = (iso: string) => {
      const d = new Date(iso);
      const day = d.toLocaleDateString('en-US', { weekday: 'short' });
      const time = d.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: 'numeric',
      });
      return { day, time };
    };

    fetch('/api/calendly-availability')
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (!data || !data.configured || !Array.isArray(data.slots) || data.slots.length === 0) return;

        slots_el.innerHTML = '';
        data.slots.forEach((slot: { start_time: string; scheduling_url: string }) => {
          const { day, time } = format_slot(slot.start_time);
          const a = document.createElement('a');
          a.className = 'cal-slot';
          a.href = slot.scheduling_url || fallback_url;
          a.innerHTML = `
            <span class="cal-slot-day">${day}</span>
            <span class="cal-slot-time">${time}</span>
            <span class="cal-slot-arrow">→</span>
          `;
          slots_el.appendChild(a);
        });
      })
      .catch(() => {
        // Silent fall-through — fallback link is already rendered.
      });
  })();
</script>
