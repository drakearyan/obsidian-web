<script>
  // Scroll-driven progress. Minimizes per-frame work:
  //   - Cache sectionTop + maxScroll on resize, not every frame
  //   - Use window.scrollY (cheap) instead of getBoundingClientRect (triggers layout)
  //   - Only write to DOM when values change
  //   - rAF throttle: one update per paint, no more
  (function initWorldScroll() {
    const section = document.querySelector<HTMLElement>('[data-world-scroll]');
    if (!section) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      section.style.setProperty('--p', '1');
      section.dataset.stage = '3';
      return;
    }

    // Cached layout values — refreshed only on resize
    let sectionTop = 0;
    let maxScroll = 1;
    let lastP = -1;
    let lastStage = -1;
    let ticking = false;

    const measure = () => {
      // offsetTop gives the section's natural document position,
      // unaffected by sticky children or current scroll state.
      // getBoundingClientRect().top + scrollY would be WRONG here
      // because the inner .world-pin is sticky and can be pinned
      // at the time measure() runs.
      let top = 0;
      let node: HTMLElement | null = section;
      while (node) {
        top += node.offsetTop;
        node = node.offsetParent as HTMLElement | null;
      }
      sectionTop = top;
      maxScroll = Math.max(1, section.offsetHeight - window.innerHeight);
    };

    const update = () => {
      ticking = false;
      const y = window.scrollY - sectionTop;
      const p = y <= 0 ? 0 : y >= maxScroll ? 1 : y / maxScroll;

      // Only write --p when it changes meaningfully (avoid style-engine thrash on idle scroll)
      if (Math.abs(p - lastP) > 0.001) {
        section.style.setProperty('--p', p.toFixed(4));
        lastP = p;
      }

      const stage = p < 0.25 ? 0 : p < 0.5 ? 1 : p < 0.75 ? 2 : 3;
      if (stage !== lastStage) {
        section.dataset.stage = String(stage);
        lastStage = stage;
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    // IntersectionObserver gate — only listen to scroll when the section
    // is anywhere near the viewport. On long pages (home scrolls ~12,000px)
    // this saves hundreds of rAF ticks while the user scrolls the services,
    // portfolio, and blog sections far below the globe.
    let scrollBound = false;
    const bind = () => {
      if (scrollBound) return;
      scrollBound = true;
      window.addEventListener('scroll', onScroll, { passive: true });
    };
    const unbind = () => {
      if (!scrollBound) return;
      scrollBound = false;
      window.removeEventListener('scroll', onScroll);
    };

    measure();
    update();

    if ('IntersectionObserver' in window) {
      // rootMargin 50% above + below = bind scroll listener when section
      // is within one viewport height of being visible. Prevents stutter
      // at the moment the user first crosses into the section.
      const io = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            bind();
            update();
          } else {
            unbind();
          }
        }
      }, { rootMargin: '50% 0px 50% 0px' });
      io.observe(section);
    } else {
      // Old browser fallback — just always listen
      bind();
    }

    window.addEventListener('resize', () => { measure(); onScroll(); }, { passive: true });
  })();
</script>

<style>
  /* ───────── Scroll-pinned container ───────── */
  .world-scroll {
    position: relative;
    /* 380vh = ~3.8 screens of scroll → smooth, deliberate zoom */
    height: 380vh;
    --p: 0;
    background: var(--bg);
    /* Isolate paint so zooming doesn't re-render the page */
    contain: layout paint;
  }

  .world-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    display: grid;
    place-items: center;
    /* Subtle vignette so the globe pops off the background */
    background:
      radial-gradient(ellipse 70% 55% at 50% 48%, rgba(233, 162, 70, 0.07), transparent 70%),
      radial-gradient(ellipse 40% 30% at 50% 100%, rgba(201, 122, 28, 0.04), transparent 80%);
    /* New stacking + paint context — scroll repaints don't bleed out */
    contain: layout paint;
    isolation: isolate;
  }

  /* ───────── Meta (corner labels) ───────── */
  .world-meta {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    z-index: 3;
  }
  .world-meta--tl {
    top: calc(var(--nav-height) + 1.25rem);
    left: 2rem;
  }
  .world-meta--tr {
    top: calc(var(--nav-height) + 1.25rem);
    right: 2rem;
  }
  /* Default: show the full descriptor, hide the short one */
  .world-meta-text--short { display: none; }
  .world-label {
    color: var(--ember);
    font-weight: 500;
  }
  .world-progress {
    width: 80px;
    height: 1px;
    background: rgba(232, 220, 196, 0.15);
    position: relative;
  }
  .world-progress-fill {
    position: absolute;
    inset: 0;
    background: var(--ember);
    transform-origin: left center;
    /* translateZ forces its own composite layer — no transition, scroll drives directly */
    transform: translateZ(0) scaleX(calc(var(--p, 0)));
    will-change: transform;
  }

  /* ───────── Globe (scaled on scroll) ───────── */
  .world-globe {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }
  .world-globe svg {
    width: min(92vmin, 820px);
    height: auto;
    display: block;
    /* Progressive zoom 1× → 14×, transform applied to the SVG itself
       so transform-origin percentages map against the SVG's own
       square box. Applying this on the outer .world-globe container
       drifts the origin west of the intended pin, because the
       container is wider than the SVG and the SVG is centered with
       horizontal padding inside it.

       The projection is rotated to Fairfax (-77.30°W, 38.85°N), so
       the pin projects exactly to SVG (500, 500). transform-origin
       50% 50% therefore zooms the globe straight into the pin from
       viewport center. To recenter on a different city, edit the
       rotate() in scripts/generate-globe-paths.mjs and re-run the
       npm globe:regenerate pipeline; the pin always lands at center
       under this convention. */
    transform-origin: 50% 50%;
    transform: translateZ(0) scale(calc(1 + var(--p, 0) * 13));
    will-change: transform;
    backface-visibility: hidden;
  }
  /* Soft amber glow behind the globe — rendered as a separate static
     element so it doesn't get scaled 14× with the globe (drop-shadow
     on a scaled element is a major perf killer). */
  .world-pin::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(92vmin, 820px);
    height: min(92vmin, 820px);
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at 50% 50%, rgba(233, 162, 70, 0.12), transparent 60%);
    pointer-events: none;
    z-index: 0;
    /* Fade out as zoom progresses — glow only makes sense at globe scale */
    opacity: calc(1 - var(--p, 0));
  }

  /* Gridlines (meridians/parallels) */
  .globe-grid {
    stroke: rgba(154, 142, 120, 0.38);
    transition: opacity 0.4s ease;
  }
  /* Fade grid as we zoom past continent view */
  [data-world-scroll][data-stage="2"] .globe-grid { opacity: 0.25; }
  [data-world-scroll][data-stage="3"] .globe-grid { opacity: 0.1; }

  /* Continents (amber line art) */
  .globe-land {
    stroke: var(--ember);
    stroke-linejoin: round;
    stroke-linecap: round;
    opacity: 0.88;
  }

  /* Fairfax pin — centralize fill/stroke so SVG stays brand-agnostic */
  .globe-pin { opacity: 0; transition: opacity 0.5s ease; }
  .globe-pin .pin-ping { stroke: var(--ember); }
  .globe-pin .pin-halo { fill: var(--ember); }
  .globe-pin .pin-dot  { fill: var(--ember); }
  [data-world-scroll][data-stage="3"] .globe-pin { opacity: 1; }

  .pin-ping {
    /* center of the circle's own bounding box — projection-agnostic
       so this rule survives future pin reprojections. */
    transform-origin: center;
    transform-box: fill-box;
    animation: pin-ping 2.4s ease-out infinite;
  }
  @keyframes pin-ping {
    0%   { transform: scale(1);   opacity: 1; }
    80%  { transform: scale(5);   opacity: 0; }
    100% { transform: scale(5);   opacity: 0; }
  }

  /* ───────── Stage text (fades between stages) ───────── */
  .world-text {
    position: relative;
    z-index: 2;
    width: min(680px, 92%);
    padding: 0 2rem;
    text-align: center;
    pointer-events: none;
    min-height: clamp(180px, 26vh, 260px);
  }

  .stage-card {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  [data-world-scroll][data-stage="0"] .stage-card[data-stage="0"],
  [data-world-scroll][data-stage="1"] .stage-card[data-stage="1"],
  [data-world-scroll][data-stage="2"] .stage-card[data-stage="2"],
  [data-world-scroll][data-stage="3"] .stage-card[data-stage="3"] {
    opacity: 1;
