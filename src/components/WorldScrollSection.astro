---
/*
  WorldScrollSection
  ──────────────────────────────────────────────────────────────
  A scroll-driven editorial hero prelude. User enters an amber
  wireframe globe; as they scroll, the globe zooms progressively
  into Virginia, landing on a Lynchburg pin. Each stage swaps a
  short editorial caption. No external libraries — pure SVG +
  CSS transforms driven by a small scroll handler. Respects
  prefers-reduced-motion by collapsing to the final stage.
*/
---

<section class="world-scroll" data-world-scroll aria-label="Intro scroll animation: globe zooms into Lynchburg, Virginia">
  <div class="world-pin">
    <!-- Top-left meta, parallels existing Hero style -->
    <div class="world-meta world-meta--tl">
      <span class="world-label">[00]</span>
      <span class="world-meta-text">FROM LYNCHBURG TO EVERYWHERE</span>
    </div>

    <!-- Top-right meta: scroll progress indicator -->
    <div class="world-meta world-meta--tr">
      <span class="world-label">SCROLL</span>
      <div class="world-progress">
        <div class="world-progress-fill"></div>
      </div>
    </div>

    <!-- Globe SVG — wireframe line art, no fills -->
    <div class="world-globe" aria-hidden="true">
      <svg viewBox="0 0 1000 1000" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Clip continents to globe disk so nothing spills out at scale 1 -->
          <clipPath id="globeClip">
            <circle cx="500" cy="500" r="380" />
          </clipPath>
        </defs>

        <!-- GRID: outer disk + parallels + meridians -->
        <g class="globe-grid" stroke-width="1" fill="none">
          <circle cx="500" cy="500" r="380" />
          <!-- Parallels (flattened ellipses fake a sphere) -->
          <ellipse cx="500" cy="500" rx="380" ry="95" />
          <ellipse cx="500" cy="500" rx="380" ry="190" />
          <ellipse cx="500" cy="500" rx="380" ry="285" />
          <!-- Meridians -->
          <ellipse cx="500" cy="500" rx="95" ry="380" />
          <ellipse cx="500" cy="500" rx="190" ry="380" />
          <ellipse cx="500" cy="500" rx="285" ry="380" />
          <!-- Equator + prime meridian -->
          <line x1="120" y1="500" x2="880" y2="500" />
          <line x1="500" y1="120" x2="500" y2="880" />
        </g>

        <!-- CONTINENTS: stylized silhouettes clipped to globe -->
        <g class="globe-land" stroke-width="2" fill="none" clip-path="url(#globeClip)">
          <!-- North America — enlarged, biased toward center-left so VA pin reads -->
          <path d="M 280 300
                   Q 310 270 360 275
                   L 420 290
                   Q 450 305 465 340
                   L 485 385
                   Q 495 415 478 445
                   L 470 480
                   Q 450 505 415 512
                   L 380 508
                   Q 345 500 330 475
                   L 315 435
                   Q 300 400 300 365
                   L 295 330 Z" />
          <!-- Central America tail -->
          <path d="M 420 500 Q 430 520 440 540 L 445 555 Q 440 562 432 555 L 420 530 Z" />
          <!-- South America -->
          <path d="M 460 560
                   Q 490 570 500 610
                   L 500 680
                   Q 490 720 470 740
                   L 458 745
                   Q 445 735 448 700
                   L 452 640
                   Q 457 590 460 560 Z" />
          <!-- Europe -->
          <path d="M 580 315
                   Q 615 310 630 335
                   L 640 360
                   Q 630 380 605 380
                   L 585 375
                   Q 570 355 580 315 Z" />
          <!-- Africa -->
          <path d="M 585 400
                   Q 620 410 635 455
                   L 638 525
                   Q 625 580 600 615
                   L 585 625
                   Q 565 595 570 540
                   L 570 470
                   Q 575 425 585 400 Z" />
          <!-- Asia -->
          <path d="M 645 300
                   Q 715 285 770 315
                   L 800 365
                   Q 790 410 745 420
                   L 680 415
                   Q 650 390 640 350
                   L 640 320 Z" />
          <!-- Southeast Asia -->
          <path d="M 720 440 Q 740 445 748 465 L 745 485 Q 735 495 718 488 L 710 470 Z" />
          <!-- Australia -->
          <path d="M 725 575
                   Q 760 570 780 595
                   L 785 625
                   Q 765 640 730 635
                   L 715 618
                   Q 710 595 725 575 Z" />
          <!-- Greenland smudge -->
          <path d="M 450 245 Q 475 240 490 260 L 488 285 Q 470 295 452 285 L 445 265 Z" />
        </g>

        <!-- VIRGINIA OUTLINE — fades in mid-zoom -->
        <g class="globe-va" stroke-width="2.5" fill="none">
          <!-- Simplified VA silhouette, positioned at VA's location on North America -->
          <path d="M 405 393
                   L 430 388
                   L 452 395
                   L 468 402
                   L 478 412
                   L 472 420
                   L 460 418
                   L 445 422
                   L 430 426
                   L 415 428
                   L 400 425
                   L 392 418
                   L 395 408
                   L 402 400 Z" />
        </g>

        <!-- LYNCHBURG PIN: on eastern edge of Virginia -->
        <g class="globe-pin">
          <!-- Ping ring -->
          <circle class="pin-ping" cx="436" cy="410" r="6" fill="none" stroke="#E9A246" stroke-width="1" />
          <!-- Soft halo -->
          <circle class="pin-halo" cx="436" cy="410" r="4" fill="#E9A246" opacity="0.28" />
          <!-- Center dot -->
          <circle class="pin-dot" cx="436" cy="410" r="2.4" fill="#E9A246" />
        </g>
      </svg>
    </div>

    <!-- STAGE TEXT: each card fades in at its stage -->
    <div class="world-text">
      <article class="stage-card" data-stage="0">
        <span class="stage-kicker">§ 00 · OBSIDIAN WEB CO.</span>
        <h2 class="stage-title">A studio anywhere <em>lives somewhere.</em></h2>
        <p class="stage-sub">Scroll — and see where.</p>
      </article>

      <article class="stage-card" data-stage="1">
        <span class="stage-kicker">§ 01 · NORTH AMERICA</span>
        <h2 class="stage-title">Design that travels, <em>for clients that don't have to.</em></h2>
        <p class="stage-sub">Remote-first. Shipped worldwide.</p>
      </article>

      <article class="stage-card" data-stage="2">
        <span class="stage-kicker">§ 02 · VIRGINIA</span>
        <h2 class="stage-title">Headquartered in the <em>Blue Ridge.</em></h2>
        <p class="stage-sub">Four hours from DC. Four minutes from the James.</p>
      </article>

      <article class="stage-card" data-stage="3">
        <span class="stage-kicker">§ 03 · LYNCHBURG, VA</span>
        <h2 class="stage-title">Built <em>right here.</em></h2>
        <p class="stage-sub">Seven counties · one studio · zero page builders.</p>
      </article>
    </div>

    <!-- Bottom hint: keeps the reader anchored during the pin -->
    <div class="world-hint">
      <span class="hint-line"></span>
      <span class="hint-text">continue</span>
    </div>
  </div>
</section>

<script>
  // Scroll-driven progress. Minimizes per-frame work:
  //   - Cache sectionTop + maxScroll on resize, not every frame
  //   - Use window.scrollY (cheap) instead of getBoundingClientRect (triggers layout)
  //   - Only write to DOM when values change
  //   - rAF throttle: one update per paint, no more
  (function initWorldScroll() {
    const section = document.querySelector<HTMLElement>('[data-world-scroll]');
    if (!section) return;

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) {
      section.style.setProperty('--p', '1');
      section.dataset.stage = '3';
      return;
    }

    // Cached layout values — refreshed only on resize
    let sectionTop = 0;
    let maxScroll = 1;
    let lastP = -1;
    let lastStage = -1;
    let ticking = false;

    const measure = () => {
      // offsetTop gives the section's natural document position,
      // unaffected by sticky children or current scroll state.
      // getBoundingClientRect().top + scrollY would be WRONG here
      // because the inner .world-pin is sticky and can be pinned
      // at the time measure() runs.
      let top = 0;
      let node: HTMLElement | null = section;
      while (node) {
        top += node.offsetTop;
        node = node.offsetParent as HTMLElement | null;
      }
      sectionTop = top;
      maxScroll = Math.max(1, section.offsetHeight - window.innerHeight);
    };

    const update = () => {
      ticking = false;
      const y = window.scrollY - sectionTop;
      const p = y <= 0 ? 0 : y >= maxScroll ? 1 : y / maxScroll;

      // Only write --p when it changes meaningfully (avoid style-engine thrash on idle scroll)
      if (Math.abs(p - lastP) > 0.001) {
        section.style.setProperty('--p', p.toFixed(4));
        lastP = p;
      }

      const stage = p < 0.25 ? 0 : p < 0.5 ? 1 : p < 0.75 ? 2 : 3;
      if (stage !== lastStage) {
        section.dataset.stage = String(stage);
        lastStage = stage;
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    measure();
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { measure(); onScroll(); }, { passive: true });
  })();
</script>

<style>
  /* ───────── Scroll-pinned container ───────── */
  .world-scroll {
    position: relative;
    /* 380vh = ~3.8 screens of scroll → smooth, deliberate zoom */
    height: 380vh;
    --p: 0;
    background: var(--bg);
    /* Isolate paint so zooming doesn't re-render the page */
    contain: layout paint;
  }

  .world-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    display: grid;
    place-items: center;
    /* Subtle vignette so the globe pops off the background */
    background:
      radial-gradient(ellipse 70% 55% at 50% 48%, rgba(233, 162, 70, 0.07), transparent 70%),
      radial-gradient(ellipse 40% 30% at 50% 100%, rgba(201, 122, 28, 0.04), transparent 80%);
    /* New stacking + paint context — scroll repaints don't bleed out */
    contain: layout paint;
    isolation: isolate;
  }

  /* ───────── Meta (corner labels) ───────── */
  .world-meta {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    z-index: 3;
  }
  .world-meta--tl {
    top: calc(var(--nav-height) + 1.25rem);
    left: 2rem;
  }
  .world-meta--tr {
    top: calc(var(--nav-height) + 1.25rem);
    right: 2rem;
  }
  .world-label {
    color: var(--ember);
    font-weight: 500;
  }
  .world-progress {
    width: 80px;
    height: 1px;
    background: rgba(232, 220, 196, 0.15);
    position: relative;
  }
  .world-progress-fill {
    position: absolute;
    inset: 0;
    background: var(--ember);
    transform-origin: left center;
    /* translateZ forces its own composite layer — no transition, scroll drives directly */
    transform: translateZ(0) scaleX(calc(var(--p, 0)));
    will-change: transform;
  }

  /* ───────── Globe (scaled on scroll) ───────── */
  .world-globe {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    /* Progressive zoom 1× → 14×, centered on Virginia (≈ 43.6%, 41%).
       translateZ(0) forces a dedicated GPU layer so scroll scaling
       doesn't trigger full-page repaints. No transition — scroll
       drives the scale directly; smoothness comes from rAF + browser
       compositor, not CSS easing. */
    transform-origin: 43.6% 41%;
    transform: translateZ(0) scale(calc(1 + var(--p, 0) * 13));
    will-change: transform;
    backface-visibility: hidden;
  }
  .world-globe svg {
    width: min(92vmin, 820px);
    height: auto;
    display: block;
    /* SVG repaint hint — helps browsers keep the globe on a single layer */
    transform: translateZ(0);
  }
  /* Soft amber glow behind the globe — rendered as a separate static
     element so it doesn't get scaled 14× with the globe (drop-shadow
     on a scaled element is a major perf killer). */
  .world-pin::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: min(92vmin, 820px);
    height: min(92vmin, 820px);
    transform: translate(-50%, -50%);
    background: radial-gradient(circle at 50% 50%, rgba(233, 162, 70, 0.12), transparent 60%);
    pointer-events: none;
    z-index: 0;
    /* Fade out as zoom progresses — glow only makes sense at globe scale */
    opacity: calc(1 - var(--p, 0));
  }

  /* Gridlines (meridians/parallels) */
  .globe-grid {
    stroke: rgba(154, 142, 120, 0.38);
    transition: opacity 0.4s ease;
  }
  /* Fade grid as we zoom past continent view */
  [data-world-scroll][data-stage="2"] .globe-grid { opacity: 0.25; }
  [data-world-scroll][data-stage="3"] .globe-grid { opacity: 0.1; }

  /* Continents (amber line art) */
  .globe-land {
    stroke: var(--ember);
    stroke-linejoin: round;
    stroke-linecap: round;
    opacity: 0.88;
  }

  /* Virginia outline — invisible until stage 2, then pops */
  .globe-va {
    stroke: var(--ember);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  [data-world-scroll][data-stage="2"] .globe-va { opacity: 0.9; }
  [data-world-scroll][data-stage="3"] .globe-va { opacity: 1; }

  /* Lynchburg pin */
  .globe-pin { opacity: 0; transition: opacity 0.5s ease; }
  [data-world-scroll][data-stage="3"] .globe-pin { opacity: 1; }

  .pin-ping {
    transform-origin: 436px 410px;
    transform-box: fill-box;
    animation: pin-ping 2.4s ease-out infinite;
  }
  @keyframes pin-ping {
    0%   { transform: scale(1);   opacity: 1; }
    80%  { transform: scale(5);   opacity: 0; }
    100% { transform: scale(5);   opacity: 0; }
  }

  /* ───────── Stage text (fades between stages) ───────── */
  .world-text {
    position: relative;
    z-index: 2;
    width: min(680px, 92%);
    padding: 0 2rem;
    text-align: center;
    pointer-events: none;
    min-height: clamp(180px, 26vh, 260px);
  }

  .stage-card {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.1rem;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  [data-world-scroll][data-stage="0"] .stage-card[data-stage="0"],
  [data-world-scroll][data-stage="1"] .stage-card[data-stage="1"],
  [data-world-scroll][data-stage="2"] .stage-card[data-stage="2"],
  [data-world-scroll][data-stage="3"] .stage-card[data-stage="3"] {
    opacity: 1;
    transform: translateY(0);
  }

  .stage-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ember);
  }
  .stage-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6.5vw, 5.25rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.028em;
    color: var(--text);
    text-wrap: balance;
  }
  .stage-title em {
    display: block;
    font-style: italic;
    color: var(--ember);
    font-weight: 400;
  }
  .stage-sub {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* ───────── Bottom hint ───────── */
  .world-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted-2);
    /* Hide the hint on the final stage — feels cleaner */
    opacity: calc(1 - var(--p, 0));
    transition: opacity 0.3s ease;
    pointer-events: none;
  }
  .hint-line {
    width: 1px;
    height: 34px;
    background: var(--border);
    position: relative;
    overflow: hidden;
  }
  .hint-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--ember);
    transform: translateY(-100%);
    animation: hint-fall 1.8s cubic-bezier(0.5, 0, 0.5, 1) infinite;
  }
  @keyframes hint-fall {
    0%   { transform: translateY(-100%); }
    50%  { transform: translateY(0); }
    100% { transform: translateY(100%); }
  }
  .hint-text {
    opacity: 0.75;
  }

  /* ───────── Responsive ───────── */
  @media (max-width: 768px) {
    .world-scroll { height: 320vh; }
    .world-globe svg { width: 88vmin; }
    .world-meta--tl { top: calc(var(--nav-height) + 0.75rem); left: 1rem; }
    .world-meta--tr { top: calc(var(--nav-height) + 0.75rem); right: 1rem; }
    .world-progress { width: 56px; }
    .world-text { padding: 0 1.25rem; }
  }

  /* ───────── Reduced motion ───────── */
  @media (prefers-reduced-motion: reduce) {
    .world-scroll { height: 100vh; }
    .world-pin { position: relative; }
    .world-globe { transition: none; transform: none; }
    .pin-ping { animation: none; display: none; }
    .hint-line::after { animation: none; }
    .stage-card { transition: none; }
  }
</style>
