---
export const prerender = true;
import PageLayout from '../layouts/PageLayout.astro';
import { service_tiers } from '../data/services';

/*
  Tier recommendation quiz.
  5 questions. Each answer has integer weights for [starter, professional, premium].
  We sum per-tier, pick the highest. Ties break toward the leftmost (Starter < Pro < Premium).
  Pure client-side JS. Result reveals inline, CTA links to /contact with a prefilled tier query param.
*/

interface Answer {
  label: string;
  weights: [number, number, number]; // [starter, professional, premium]
}
interface Question {
  q: string;
  answers: Answer[];
}

const questions: Question[] = [
  {
    q: 'How many pages does your site need?',
    answers: [
      { label: '1 to 3 pages — home, about, contact', weights: [3, 0, 0] },
      { label: '4 to 8 pages — services, blog, more', weights: [0, 3, 1] },
      { label: '9+ pages, or I\'m not sure yet',       weights: [0, 1, 3] },
    ],
  },
  {
    q: 'Do you need to sell online?',
    answers: [
      { label: 'No — just want a presence + contact form', weights: [2, 1, 0] },
      { label: 'Maybe later — start simple, grow into it',  weights: [1, 2, 1] },
      { label: 'Yes — payments, catalog, e-commerce',       weights: [0, 0, 4] },
    ],
  },
  {
    q: 'How fast do you need this live?',
    answers: [
      { label: 'Within a week — the faster the better', weights: [3, 1, 0] },
      { label: '2 to 3 weeks works',                    weights: [1, 3, 1] },
      { label: 'No rush — I want it done right',        weights: [0, 2, 2] },
    ],
  },
  {
    q: 'How much content do you already have written?',
    answers: [
      { label: 'Most of it — just needs polish',    weights: [2, 2, 1] },
      { label: 'Some — but I need help filling gaps', weights: [1, 2, 2] },
      { label: 'Almost none — I\'ll need help',     weights: [0, 1, 3] },
    ],
  },
  {
    q: 'What\'s the #1 thing the site needs to do?',
    answers: [
      { label: 'Show up on Google so people find me', weights: [1, 3, 1] },
      { label: 'Look professional and answer questions', weights: [3, 1, 0] },
      { label: 'Drive leads / bookings / sales', weights: [0, 2, 3] },
    ],
  },
];

const tier_meta = [
  { tier: service_tiers[0], id: 'starter', kicker: 'Recommended tier' },
  { tier: service_tiers[1], id: 'professional', kicker: 'Recommended tier' },
  { tier: service_tiers[2], id: 'premium', kicker: 'Recommended tier' },
];
---

<PageLayout
  title="Which tier do I need?"
  description="Answer 5 questions. Get a tier recommendation — Starter, Professional, or Premium — plus a ballpark price and next step."
>
  <section class="quiz-hero">
    <div class="container">
      <span class="section-label">[ ? ] / recommendation quiz</span>
      <h1 class="quiz-title">Which tier fits <em class="serif-accent">your project?</em></h1>
      <p class="quiz-intro">
        5 quick questions. No email required. At the end you get a tier recommendation + a ballpark price range. If you'd rather just talk, <a href="/contact">book a 30-min call</a> instead.
      </p>
    </div>
  </section>

  <section class="quiz-section">
    <div class="container">
      <form id="quiz-form" class="quiz-form" novalidate>
        {questions.map((q, qi) => (
          <fieldset class="quiz-q">
            <legend>
              <span class="quiz-q-num">§ {String(qi + 1).padStart(2, '0')}</span>
              <span class="quiz-q-text">{q.q}</span>
            </legend>
            <div class="quiz-answers">
              {q.answers.map((a, ai) => (
                <label class="quiz-answer">
                  <input
                    type="radio"
                    name={`q${qi}`}
                    value={a.weights.join(',')}
                    required
                  />
                  <span class="quiz-answer-inner">
                    <span class="quiz-answer-letter">{String.fromCharCode(65 + ai)}</span>
                    <span class="quiz-answer-text">{a.label}</span>
                  </span>
                </label>
              ))}
            </div>
          </fieldset>
        ))}

        <div class="quiz-submit-wrap">
          <button type="submit" class="btn-primary btn-glow" id="quiz-submit">
            See my recommendation
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </button>
          <p class="quiz-submit-note" id="quiz-error" role="alert" hidden>Pick an answer for every question first.</p>
        </div>
      </form>

      <div id="quiz-result" class="quiz-result" hidden aria-live="polite">
        <!-- Populated by JS — one of three result cards rendered below -->
      </div>

      <!-- Hidden template data the JS reads to build the result card -->
      <div id="quiz-tier-data" hidden>
        {tier_meta.map((t, i) => (
          <div
            data-tier-index={i}
            data-tier-name={t.tier.name}
            data-tier-id={t.tier.id}
            data-tier-price={t.tier.priceDisplay}
            data-tier-timeline={t.tier.timeline}
            data-tier-tagline={t.tier.tagline}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const form = document.getElementById('quiz-form') as HTMLFormElement | null;
  const result = document.getElementById('quiz-result') as HTMLElement | null;
  const error = document.getElementById('quiz-error') as HTMLElement | null;
  const submitBtn = document.getElementById('quiz-submit') as HTMLButtonElement | null;
  const tierData = document.getElementById('quiz-tier-data');

  if (!form || !result || !error || !submitBtn || !tierData) {
    // Guard against missing DOM — should never happen, but keeps TS honest
  } else {
    const tiers = Array.from(tierData.querySelectorAll<HTMLElement>('[data-tier-index]')).map((el) => ({
      name: el.dataset.tierName || '',
      id: el.dataset.tierId || '',
      price: el.dataset.tierPrice || '',
      timeline: el.dataset.tierTimeline || '',
      tagline: el.dataset.tierTagline || '',
    }));

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const data = new FormData(form);
      const scores = [0, 0, 0];
      let answered = 0;

      for (let i = 0; i < 5; i++) {
        const v = data.get(`q${i}`);
        if (typeof v === 'string') {
          const weights = v.split(',').map(Number);
          scores[0] += weights[0] || 0;
          scores[1] += weights[1] || 0;
          scores[2] += weights[2] || 0;
          answered++;
        }
      }

      if (answered < 5) {
        error.hidden = false;
        return;
      }
      error.hidden = true;

      // Pick winner (ties go to the higher tier — most complete solution)
      let winIdx = 0;
      for (let i = 1; i < 3; i++) {
        if (scores[i] >= scores[winIdx]) winIdx = i;
      }
      const winner = tiers[winIdx];
      const total = scores[0] + scores[1] + scores[2];
      const pct = total > 0 ? Math.round((scores[winIdx] / total) * 100) : 0;

      result.innerHTML = `
        <div class="result-card">
          <span class="result-kicker">Recommended tier · ${pct}% match</span>
          <h2 class="result-name">${winner.name}</h2>
          <p class="result-tagline">${winner.tagline}</p>
          <div class="result-meta">
            <div class="result-meta-item">
              <div class="result-meta-label">Price range</div>
              <div class="result-meta-value">${winner.price}</div>
            </div>
            <div class="result-meta-item">
              <div class="result-meta-label">Timeline</div>
              <div class="result-meta-value">${winner.timeline}</div>
            </div>
          </div>
          <div class="result-actions">
            <a href="/contact?tier=${winner.id}" class="btn-primary btn-glow">
              Start a ${winner.name.split(' ')[0]} project
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a href="/services#${winner.id}" class="arrow-link">
              See the full spec
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
          <details class="result-details">
            <summary>How was this calculated?</summary>
            <p>Starter scored ${scores[0]}, Professional scored ${scores[1]}, Premium scored ${scores[2]}. Each answer carries weights for each tier; the highest-scoring tier wins. If the recommendation doesn't feel right, book a <a href="/contact">discovery call</a> and we'll talk it through.</p>
          </details>
        </div>
      `;

      result.hidden = false;
      submitBtn.textContent = 'Retake quiz';
      submitBtn.onclick = (ev) => {
        ev.preventDefault();
        form.reset();
        result.hidden = true;
        result.innerHTML = '';
        submitBtn.textContent = 'See my recommendation';
        submitBtn.onclick = null;
        form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      };

      result.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>

<style>
  .quiz-hero { padding: 8rem 0 3rem; }
  .quiz-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1.5rem;
  }
  .quiz-intro {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 680px;
  }
  .quiz-intro a { color: var(--ember); text-decoration: none; }
  .quiz-intro a:hover { text-decoration: underline; }

  .quiz-section { padding: 2rem 0 6rem; }

  .quiz-form {
    max-width: 820px;
    display: grid;
    gap: 3rem;
  }

  .quiz-q {
    border: 0;
    padding: 0;
    margin: 0;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }
  .quiz-q legend {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .quiz-q-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ember);
  }
  .quiz-q-text {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.5vw, 1.9rem);
    line-height: 1.2;
    color: var(--text);
  }

  .quiz-answers {
    display: grid;
    gap: 0.75rem;
  }

  .quiz-answer {
    cursor: pointer;
    display: block;
  }
  .quiz-answer input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .quiz-answer-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .quiz-answer:hover .quiz-answer-inner {
    border-color: var(--ember);
  }
  .quiz-answer input:checked + .quiz-answer-inner {
    border-color: var(--ember);
    background: rgba(233, 162, 70, 0.06);
    box-shadow: 0 0 0 1px var(--ember);
  }
  .quiz-answer input:focus-visible + .quiz-answer-inner {
    outline: none;
    border-color: var(--ember);
    box-shadow: 0 0 0 3px var(--ember);
  }
  .quiz-answer-letter {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ember);
    letter-spacing: 0.1em;
    min-width: 1.5rem;
  }
  .quiz-answer-text {
    color: var(--text);
    font-size: 0.98rem;
  }

  .quiz-submit-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .quiz-submit-note {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--flame);
    letter-spacing: 0.04em;
  }

  .quiz-result {
    margin-top: 4rem;
    max-width: 820px;
  }
  .quiz-result .result-card {
    background: var(--surface);
    border: 1px solid var(--ember);
    border-radius: var(--radius);
    padding: 3rem 2.5rem;
    position: relative;
    box-shadow: 0 20px 60px rgba(233, 162, 70, 0.12);
  }
  .quiz-result .result-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ember);
  }
  .quiz-result .result-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 0.75rem;
    color: var(--text);
  }
  .quiz-result .result-tagline {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
    max-width: 560px;
    margin-bottom: 2rem;
  }
  .quiz-result .result-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }
  .quiz-result .result-meta-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }
  .quiz-result .result-meta-value {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--text);
  }
  .quiz-result .result-actions {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .quiz-result .result-details {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .quiz-result .result-details summary {
    cursor: pointer;
    padding: 0.5rem 0;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
  .quiz-result .result-details p {
    margin-top: 0.75rem;
    line-height: 1.55;
    color: var(--muted);
  }
  .quiz-result .result-details a {
    color: var(--ember);
    text-decoration: none;
  }
</style>
