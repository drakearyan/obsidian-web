---
export const prerender = true;
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'blog'> }
const { post } = Astro.props;
const { Content, headings } = await render(post);

// Build table of contents from h2 + h3 headings. Only render TOC if
// the post has at least 3 sections — otherwise it's visual clutter.
const toc_items = headings.filter((h) => h.depth === 2 || h.depth === 3);
const show_toc = toc_items.length >= 3;

const all_posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = all_posts.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const related = sorted.filter((p) => p.id !== post.id).slice(0, 3);

const category_labels: Record<string, string> = {
  design: 'Design',
  seo: 'SEO',
  performance: 'Performance',
  business: 'Business',
  lynchburg: 'Lynchburg',
};

const format_date = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    author: { '@type': 'Person', name: post.data.author },
    datePublished: post.data.publishDate.toISOString(),
    ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
    mainEntityOfPage: `https://obsidianwebco.com/blog/${post.id}/`,
  },
];
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  jsonLd={jsonLd}
>

  <article class="post">
    <header class="post-header">
      <div class="container container--narrow">
        <nav class="post-crumbs">
          <a href="/blog">← All essays</a>
        </nav>
        <div class="post-head-meta">
          <span class="post-head-cat">{category_labels[post.data.category]}</span>
          <time datetime={post.data.publishDate.toISOString()}>{format_date(post.data.publishDate)}</time>
          <span>{post.data.readingTime} min read</span>
        </div>
        <h1 class="post-head-title">{post.data.title}</h1>
        <p class="post-head-desc">{post.data.description}</p>
        <div class="post-author">
          <span class="author-avatar">DR</span>
          <div>
            <div class="author-name">{post.data.author}</div>
            <div class="author-role">Founder, Obsidian Web Co.</div>
          </div>
        </div>
      </div>
    </header>

    <div class="post-body">
      <div class="container container--narrow post-body-inner">
        {show_toc && (
          <aside class="post-toc" aria-label="Table of contents">
            <div class="toc-sticky">
              <div class="toc-label">On this page</div>
              <ol class="toc-list">
                {toc_items.map((h) => (
                  <li class={`toc-item toc-item--h${h.depth}`}>
                    <a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
                  </li>
                ))}
              </ol>
            </div>
          </aside>
        )}

        <div class="prose">
          <Content />
        </div>

        {post.data.tags.length > 0 && (
          <div class="post-tags">
            <span class="tags-label">Tags</span>
            {post.data.tags.map((t) => <span class="tag-pill">{t}</span>)}
          </div>
        )}
      </div>
    </div>

    {related.length > 0 && (
      <section class="post-related">
        <div class="container">
          <div class="related-head">
            <span class="section-label">[ next ] / more essays</span>
            <h2 class="related-title">Keep <em class="serif-accent">reading.</em></h2>
          </div>
          <ul class="related-list">
            {related.map((r) => (
              <li>
                <a href={`/blog/${r.id}/`} class="related-card">
                  <span class="related-cat">{category_labels[r.data.category]}</span>
                  <h3 class="related-post-title">{r.data.title}</h3>
                  <p class="related-desc">{r.data.description}</p>
                  <span class="related-read">Read essay →</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <CTASection
      heading="Have a project that needs this kind of thinking?"
      subheading="Obsidian builds websites that rank, convert, and load fast. Let's see if your next one is a fit."
    />
  </article>
</PageLayout>

<script>
  // TOC scroll-spy — highlights the currently-visible section's link in
  // the sticky sidebar. Uses IntersectionObserver with a generous
  // rootMargin so the "current" heading changes when the section is
  // near the top of the viewport, not when it enters the bottom.
  const toc_links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
  if (toc_links.length > 0) {
    const link_map = new Map<string, HTMLAnchorElement>();
    toc_links.forEach((a) => {
      const slug = a.dataset.tocLink;
      if (slug) link_map.set(slug, a);
    });

    const io = new IntersectionObserver(
      (entries) => {
        // Find entries currently intersecting; pick the top-most
        const active = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
        if (!active) return;
        toc_links.forEach((a) => a.classList.remove('is-current'));
        const link = link_map.get(active.target.id);
        if (link) link.classList.add('is-current');
      },
      {
        rootMargin: '-100px 0px -70% 0px',
        threshold: 0,
      }
    );

    link_map.forEach((_, slug) => {
      const el = document.getElementById(slug);
      if (el) io.observe(el);
    });
  }
</script>

<style>
  .container--narrow { max-width: 760px; }

  /* Header */
  .post-header {
    padding: 7rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .post-crumbs {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 2.5rem;
  }

  .post-crumbs a {
    color: var(--muted);
    text-decoration: none;
  }

  .post-crumbs a:hover { color: var(--ember); }

  .post-head-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .post-head-cat { color: var(--ember); }

  .post-head-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5.5vw, 4.25rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }

  .post-head-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--muted);
    line-height: 1.45;
    margin-bottom: 2.5rem;
    max-width: 640px;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    background: var(--ember);
    color: var(--text-on-ember);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
  }

  .author-name {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text);
  }

  .author-role {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  /* Body */
  .post-body {
    padding: 4rem 0 5rem;
  }

  /* Sticky TOC sidebar — floats to the left of the reading column on
     screens wider than 1200px. Hidden on narrower screens (the reading
     column stays centered with no intrusion). */
  .post-body-inner {
    position: relative;
  }
  .post-toc {
    display: none;
  }
  @media (min-width: 1200px) {
    .post-toc {
      display: block;
      position: absolute;
      top: 0;
      left: calc((100vw - 760px) / -2 + 2rem);
      width: calc((100vw - 760px) / 2 - 3rem);
      max-width: 260px;
      height: 100%;
      pointer-events: none; /* let the sticky child take clicks */
    }
    .toc-sticky {
      position: sticky;
      top: calc(var(--nav-height) + 2rem);
      pointer-events: auto;
      padding-right: 1rem;
    }
  }
  .toc-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ember);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
    max-height: calc(100vh - var(--nav-height) - 6rem);
    overflow-y: auto;
  }
  .toc-item a {
    display: block;
    font-size: 0.82rem;
    line-height: 1.4;
    color: var(--muted);
    text-decoration: none;
    padding: 0.25rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.75rem;
    margin-left: -0.75rem;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .toc-item--h3 a { padding-left: 1.5rem; font-size: 0.78rem; }
  .toc-item a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .toc-item a.is-current {
    color: var(--ember);
    border-left-color: var(--ember);
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text);
  }

  .prose :global(p) {
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.1;
    margin: 3.5rem 0 1.25rem;
    letter-spacing: -0.025em;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.2;
    margin: 2.5rem 0 0.75rem;
  }

  .prose :global(h4) {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ember);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(a) {
    color: var(--ember);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--text);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
    color: var(--text);
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(ul li::marker) { color: var(--ember); }
  .prose :global(ol li::marker) { color: var(--ember); font-family: var(--font-mono); }

  .prose :global(blockquote) {
    border-left: 2px solid var(--ember);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text);
    line-height: 1.5;
  }

  .prose :global(strong) { color: var(--text); font-weight: 500; }

  .prose :global(em) {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ember);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--surface2);
    padding: 0.15rem 0.45rem;
    border-radius: var(--radius);
    color: var(--ember);
  }

  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--text);
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
    position: relative;
  }

  .prose :global(hr::after) {
    content: '◆';
    position: absolute;
    top: -0.7rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--bg);
    padding: 0 0.75rem;
    color: var(--ember);
    font-size: 0.8rem;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.95rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.85rem 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }

  .prose :global(th) {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ember);
    font-weight: 500;
    background: var(--surface);
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin: 2rem 0;
  }

  /* Tags */
  .post-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .tags-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-right: 0.5rem;
  }

  .tag-pill {
    padding: 0.3rem 0.75rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* Related */
  .post-related {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .related-head { margin-bottom: 3rem; max-width: 900px; }

  .related-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    margin-top: 0.5rem;
  }

  .related-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .related-list { grid-template-columns: 1fr; }
  }

  .related-card {
    display: block;
    padding: 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .related-card:hover {
    border-color: var(--ember);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .related-cat {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ember);
    margin-bottom: 0.9rem;
  }

  .related-post-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    line-height: 1.15;
    margin-bottom: 0.65rem;
  }

  .related-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.55;
    margin-bottom: 1rem;
  }

  .related-read {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ember);
  }
</style>
