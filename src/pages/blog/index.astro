---
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { getCollection } from 'astro:content';

const all_posts = await getCollection('blog', ({ data }) => !data.draft);
const posts = all_posts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const featured = posts.filter((p) => p.data.featured).slice(0, 1)[0];
const rest = posts.filter((p) => p.id !== featured?.id);

const category_labels: Record<string, string> = {
  design: 'Design',
  seo: 'SEO',
  performance: 'Performance',
  business: 'Business',
  lynchburg: 'Lynchburg',
};

const format_date = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<PageLayout
  title="Blog"
  description="Essays on small-business web design, SEO, and performance — written for Lynchburg owners, not other developers."
>
  <section class="blog-hero">
    <div class="container">
      <div class="blog-hero-inner">
        <span class="section-label">[ i ] / journal</span>
        <h1 class="blog-hero-title">Field notes on <em class="serif-accent">building better sites.</em></h1>
        <p class="blog-hero-intro">
          Essays on web design, SEO, and performance — written for small-business owners, not other developers. No jargon, no filler, no listicles that took ten minutes to generate.
        </p>
      </div>
    </div>
  </section>

  {featured && (
    <section class="blog-featured">
      <div class="container">
        <a href={`/blog/${featured.id}/`} class="featured-link">
          <div class="featured-meta">
            <span class="featured-tag">Featured</span>
            <span class="featured-cat">{category_labels[featured.data.category]}</span>
          </div>
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          <div class="featured-foot">
            <time datetime={featured.data.publishDate.toISOString()}>{format_date(featured.data.publishDate)}</time>
            <span>{featured.data.readingTime} min read</span>
            <span class="read-on">
              Read essay
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  <section class="blog-list">
    <div class="container">
      <div class="list-head">
        <span class="section-label">[ ii ] / all essays</span>
        <h2 class="list-title">The <em class="serif-accent">archive.</em></h2>
        <nav class="blog-cats" aria-label="Blog categories">
          <span class="blog-cats-label">Browse:</span>
          {Object.entries(category_labels).map(([slug, label]) => (
            <a href={`/blog/category/${slug}`} class="blog-cat-pill">{label}</a>
          ))}
        </nav>
      </div>

      <ul class="post-list">
        {rest.map((p, i) => (
          <li class="post-row">
            <a href={`/blog/${p.id}/`} class="post-link">
              <span class="post-index">{String(i + 1).padStart(2, '0')}</span>
              <div class="post-body">
                <div class="post-meta">
                  <span class="post-cat">{category_labels[p.data.category]}</span>
                  <time datetime={p.data.publishDate.toISOString()}>{format_date(p.data.publishDate)}</time>
                  <span>{p.data.readingTime} min</span>
                </div>
                <h3 class="post-title">{p.data.title}</h3>
                <p class="post-desc">{p.data.description}</p>
              </div>
              <span class="post-arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection
    heading="Want essays like these in your inbox?"
    subheading="One essay a month on small-business web design, no spam, no tracking, unsubscribe anytime. Email Drake to join the list."
    ctaText="Email to subscribe"
  />
</PageLayout>

<style>
  .blog-hero { padding: 8rem 0 3rem; }
  .blog-hero-inner { max-width: 900px; }
  .blog-hero-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1.5rem;
  }
  .blog-hero-intro {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 640px;
  }

  /* Featured */
  .blog-featured { padding: 2rem 0 4rem; }

  .featured-link {
    display: block;
    padding: 3rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: inherit;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
    position: relative;
  }

  .featured-link:hover {
    border-color: var(--ember);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .featured-tag {
    color: var(--ember);
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--ember);
    border-radius: var(--radius-pill);
  }

  .featured-cat { color: var(--muted); }

  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.05;
    margin-bottom: 1rem;
    max-width: 880px;
  }

  .featured-desc {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 720px;
    margin-bottom: 1.75rem;
  }

  .featured-foot {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.06em;
    flex-wrap: wrap;
  }

  .read-on {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ember);
  }

  /* Archive list */
  .blog-list { padding: 5rem 0; border-top: 1px solid var(--border); }

  .list-head { margin-bottom: 3rem; max-width: 900px; }

  .blog-cats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    margin-top: 1.5rem;
  }
  .blog-cats-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-right: 0.25rem;
  }
  .blog-cat-pill {
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .blog-cat-pill:hover {
    color: var(--ember);
    border-color: var(--ember);
    text-decoration: none;
  }

  .list-title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1;
    margin-top: 0.5rem;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--border);
  }

  .post-row {
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 2rem;
    padding: 2.25rem 0.5rem;
    color: inherit;
    text-decoration: none;
    align-items: center;
    transition: background 0.25s ease, padding 0.25s ease;
  }

  .post-link:hover {
    background: var(--surface);
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    text-decoration: none;
  }

  @media (max-width: 700px) {
    .post-link { grid-template-columns: auto 1fr; gap: 1.25rem; padding: 1.75rem 0.25rem; }
    .post-arrow { display: none; }
  }

  .post-index {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ember);
    letter-spacing: 0.1em;
    align-self: start;
    padding-top: 0.4rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-cat { color: var(--ember); }

  .post-title {
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.5vw, 2rem);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .post-link:hover .post-title { color: var(--ember); }

  .post-desc {
    font-size: 0.98rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 720px;
  }

  .post-arrow {
    color: var(--muted);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .post-link:hover .post-arrow {
    color: var(--ember);
    transform: translateX(4px);
  }
</style>
