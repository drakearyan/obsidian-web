---
import PageLayout from '../layouts/PageLayout.astro';
import CTASection from '../components/CTASection.astro';

// Update this block at the start of each month. Inspired by nownownow.com
// — a simple, honest "here's what I'm doing right now" page that signals
// you're a real person running a real business, not a set-and-forget site.
const now_state = {
  status: 'Accepting new projects',
  availability: 'Next open project slot: May 2026',
  responseThisWeek: 'Within 4 hours, business days',
  lastUpdated: '2026-04-17',
  workingOn: [
    'Finalizing Phase 5–7 polish on the Obsidian Web Co. site itself (yes, the site you\'re on right now).',
    'Two client sites in discovery — a Lynchburg restaurant and a Forest-area professional service.',
    'Writing the next monthly essay — topic: "why your GBP ranking is what actually matters."',
  ],
  wrappedRecently: [
    'Shipped the new editorial homepage with scroll-driven globe zoom.',
    'Published 2 new Lynchburg-specific essays on the blog.',
    'Set up Smartlead cold outreach infrastructure with a 2-week domain warm-up.',
  ],
  reading: [
    'Refactoring UI — Adam Wathan & Steve Schoger',
    'The Mom Test — Rob Fitzpatrick',
    'Traction — Gino Wickman',
  ],
  notDoing: [
    'Cheap template sites. Not competing on \$400 quotes.',
    'Anything that needs an "account manager" between you and me.',
    'SEO spam / link-building schemes / Fiverr-tier work.',
  ],
};

const format_date = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<PageLayout
  title="Now"
  description="What Drake is working on right now at Obsidian Web Co. — current availability, response time, recent shipments, and what's in flight."
>
  <section class="now-hero">
    <div class="container">
      <span class="section-label">[ • ] / now</span>
      <h1 class="now-title">What I'm <em class="serif-accent">working on now.</em></h1>
      <p class="now-intro">
        A monthly snapshot of where the studio actually is. Updated at the start of each month — inspired by <a href="https://nownownow.com" target="_blank" rel="noopener">nownownow.com</a>. If something here changed your mind about reaching out, <a href="/contact">say hi</a>.
      </p>
      <p class="now-updated">Last updated: {format_date(now_state.lastUpdated)}</p>
    </div>
  </section>

  <section class="now-status-sec">
    <div class="container">
      <div class="now-status">
        <div class="status-card status-card--main">
          <span class="status-dot"></span>
          <div>
            <div class="status-label">Status</div>
            <div class="status-value">{now_state.status}</div>
          </div>
        </div>
        <div class="status-card">
          <div class="status-label">Availability</div>
          <div class="status-value">{now_state.availability}</div>
        </div>
        <div class="status-card">
          <div class="status-label">Response this week</div>
          <div class="status-value">{now_state.responseThisWeek}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="now-cols">
    <div class="container">
      <div class="now-grid">
        <div class="now-col">
          <span class="section-label">[ i ] / in flight</span>
          <h2 class="col-title">Working on</h2>
          <ul>{now_state.workingOn.map((item) => <li>{item}</li>)}</ul>
        </div>

        <div class="now-col">
          <span class="section-label">[ ii ] / last 30 days</span>
          <h2 class="col-title">Recently shipped</h2>
          <ul>{now_state.wrappedRecently.map((item) => <li>{item}</li>)}</ul>
        </div>

        <div class="now-col">
          <span class="section-label">[ iii ] / reading</span>
          <h2 class="col-title">On the desk</h2>
          <ul>{now_state.reading.map((item) => <li>{item}</li>)}</ul>
        </div>

        <div class="now-col">
          <span class="section-label">[ iv ] / not doing</span>
          <h2 class="col-title">Actively not doing</h2>
          <ul>{now_state.notDoing.map((item) => <li>{item}</li>)}</ul>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Still the right time?"
    subheading="If what I'm working on above lines up with what you need, reach out. I'll tell you honestly whether we'd be a good fit."
    ctaText="Start a conversation"
    ctaHref="/contact"
  />
</PageLayout>

<style>
  .now-hero { padding: 8rem 0 3rem; }
  .now-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1.5rem;
  }
  .now-intro {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 680px;
  }
  .now-intro a { color: var(--ember); text-decoration: none; }
  .now-intro a:hover { text-decoration: underline; }
  .now-updated {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-top: 1.25rem;
  }

  .now-status-sec { padding: 2rem 0 3rem; }
  .now-status {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2rem 0;
  }
  @media (max-width: 768px) {
    .now-status { grid-template-columns: 1fr; }
  }
  .status-card {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .status-card--main { border-right: 1px solid var(--border); padding-right: 1rem; }
  @media (max-width: 768px) { .status-card--main { border-right: 0; border-bottom: 1px solid var(--border); padding-right: 0; padding-bottom: 1rem; } }
  .status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 12px #4ade80;
    animation: now-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes now-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .status-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .status-value {
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text);
    line-height: 1.3;
  }

  .now-cols { padding: 3rem 0 5rem; }
  .now-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }
  @media (max-width: 768px) { .now-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

  .now-col .col-title {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 2.5vw, 2.25rem);
    line-height: 1.1;
    margin: 0.75rem 0 1.25rem;
  }
  .now-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }
  .now-col li {
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--text);
    padding-left: 1.25rem;
    position: relative;
  }
  .now-col li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--ember);
  }
</style>
