---
export const prerender = true;
import PageLayout from '../../layouts/PageLayout.astro';
import CTASection from '../../components/CTASection.astro';

const resources = [
  // PILLARS — long-form topic hubs that link out to cluster posts.
  // Add a new pillar by dropping a .astro file at /resources/<slug>
  // and listing it here.
  {
    kind: 'Pillar topic',
    title: 'Northern Virginia web design — the long version',
    body: 'Everything I learned pivoting Obsidian to Fairfax County: the niche, the pricing, the bilingual angle, the cold-call sprint, why ethnic-restaurant corridors matter without saying "ethnic." Links to every cluster essay underneath.',
    href: '/resources/nova-web-design',
    cta: 'Read the pillar',
  },
  // FREE DOWNLOADS — lead-magnet PDFs and templates. Each card here
  // routes through /audit (which captures email) until the PDF exists.
  // Once a PDF is in /public/downloads, swap the href and remove the
  // routing note from the body copy.
  {
    kind: 'Free download',
    title: 'Google Business Profile setup checklist',
    body: "23-step checklist I run on every new client — categories, photos, hours, services, FAQ, weekly posts, review-response cadence. The thing that puts you on the map for 'best [thing] near me.' Email-gated; sent the second you opt in.",
    href: '/audit?ref=gbp-checklist',
    cta: 'Get the checklist',
  },
  {
    kind: 'Free download',
    title: 'Restaurant menu page template (HTML + Notion)',
    body: 'The menu section I build for every restaurant client — semantic HTML for accessibility, Notion mirror for owners who edit weekly, structured-data schema so Google can show dishes in search. Steal the structure; the markup is yours.',
    href: '/audit?ref=menu-template',
    cta: 'Get the template',
  },
  {
    kind: 'Free download',
    title: 'First 90 days of small-business outreach (the plan I follow)',
    body: 'The cold-call + email + GBP sprint plan I use for new local markets — 14-day call cadence, exact opener, objection bank, scoring rubric. Built around a $2,000 ticket. Adapt it; use it; ignore it.',
    href: '/audit?ref=90-day-plan',
    cta: 'Get the plan',
  },
  {
    kind: 'Free tool',
    title: '5-Minute Website Audit',
    body: "Send me your URL. I run PageSpeed, accessibility, SEO, and conversion checks — send back a 1-page PDF with what's broken and what's worth fixing.",
    href: '/audit',
    cta: 'Get my audit',
  },
  {
    kind: 'Free tool',
    title: 'Pricing Calculator',
    body: "Answer 6 questions. Get a ballpark quote. Anchored to the same Starter / Professional / Premium tiers published on the Services page.",
    href: '/calculator',
    cta: 'Try the calculator',
  },
  {
    kind: 'Free tool',
    title: 'Tier recommendation quiz',
    body: "5 questions. No email required. I recommend Starter, Professional, or Premium based on what you actually need — with the ballpark price for each.",
    href: '/quiz',
    cta: 'Take the quiz',
  },
  {
    kind: 'Reference',
    title: 'Plain-English glossary',
    body: "Fifteen terms small-business owners hear (Lighthouse, Core Web Vitals, schema, CTA, etc.) defined the way they'd be explained at a coffee shop.",
    href: '/resources/glossary',
    cta: 'Read the glossary',
  },
  {
    kind: 'Example',
    title: 'Proposal example',
    body: "A sanitized example of the proposal you'd get after a discovery call. Scope, timeline, deliverables, payment schedule — zero mystery.",
    href: '/resources/proposal-example',
    cta: 'See the proposal',
  },
  {
    kind: 'Example',
    title: 'Kickoff questionnaire preview',
    body: "The 11 sections I'll ask you about before we build — one sample question each so you know what's coming and aren't surprised.",
    href: '/resources/what-ill-ask',
    cta: "See what I'll ask",
  },
  {
    kind: 'Guide',
    title: 'Tech stack & ongoing costs',
    body: 'Astro, Tailwind, Vercel, Formspree, Mailchimp. What we use, why, and what it costs you if you self-host after launch.',
    href: '/resources/tech-stack',
    cta: 'See the stack',
  },
  {
    kind: 'Guide',
    title: 'Referral program',
    body: "Send a Lynchburg business my way. If they sign, you get paid. \$100 for friends, 10% for past clients, 15% for partners.",
    href: '/refer',
    cta: 'Refer someone',
  },
  {
    kind: 'Library',
    title: 'Essays on web design, SEO, performance',
    body: "Field notes written for owners, not other developers. Categories: design, SEO, performance, business, Lynchburg.",
    href: '/blog',
    cta: 'Read the essays',
  },
  {
    kind: 'Status',
    title: 'Roadmap',
    body: "What's coming next at Obsidian Web Co. — quarterly plan, shipped work, what's planned but not committed.",
    href: '/roadmap',
    cta: 'See the roadmap',
  },
];
---

<PageLayout
  title="Resources"
  description="Free tools, guides, and essays from Obsidian Web Co. — website audits, pricing calculator, tech stack transparency, referral program, and more."
>
  <section class="res-hero">
    <div class="container">
      <span class="section-label">[ i ] / resources</span>
      <h1 class="res-title">Free tools &amp; <em class="serif-accent">honest guides.</em></h1>
      <p class="res-intro">
        Everything here is free. No email gate on the calculator. The audit does ask for your email — because I have to send the PDF somewhere — but I don't add you to anything. The idea is: if you find any of it useful, you already know where to reach me.
      </p>
    </div>
  </section>

  <section class="res-grid-section">
    <div class="container">
      <ul class="res-grid">
        {resources.map((r, i) => (
          <li class="res-card">
            <a href={r.href} class="res-link">
              <div class="res-num">{String(i + 1).padStart(2, '0')}</div>
              <div class="res-body">
                <span class="res-kind">{r.kind}</span>
                <h2 class="res-name">{r.title}</h2>
                <p class="res-desc">{r.body}</p>
                <span class="res-cta">
                  {r.cta}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                    <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection
    heading="Missing something?"
    subheading="If there's a guide or tool you wish existed, tell me. Most of what's here started as a question a client asked."
    ctaText="Ask for it"
  />
</PageLayout>

<style>
  .res-hero { padding: 8rem 0 3rem; }
  .res-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1.5rem;
  }
  .res-intro {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 680px;
  }

  .res-grid-section { padding: 3rem 0 5rem; }
  .res-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 768px) { .res-grid { grid-template-columns: 1fr; } }

  .res-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .res-card:hover { border-color: var(--ember); transform: translateY(-2px); }

  .res-link {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1.5rem;
    padding: 2rem;
    color: inherit;
    text-decoration: none;
  }
  .res-link:hover { text-decoration: none; }
  @media (max-width: 500px) {
    .res-link { grid-template-columns: 1fr; gap: 0.75rem; padding: 1.5rem; }
  }

  .res-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 2.25rem;
    color: var(--ember);
    line-height: 1;
  }

  .res-kind {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--muted);
  }
  .res-name {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    line-height: 1.15;
    margin: 0.5rem 0 0.75rem;
  }
  .res-desc {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }
  .res-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ember);
    transition: gap 0.2s ease;
  }
  .res-link:hover .res-cta { gap: 0.75rem; }
</style>
