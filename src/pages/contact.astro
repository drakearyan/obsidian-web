---
export const prerender = true;
import PageLayout from '../layouts/PageLayout.astro';
import { site } from '../data/site';

const formspree_id = import.meta.env.PUBLIC_FORMSPREE_ID || 'YOUR_FORMSPREE_ID';

/*
  Tier-aware routing. Pages like /quiz and /web-design-* link here with a
  ?tier=starter|professional|premium query param. We prefill the Budget +
  Project Type selects AND show a small "Based on your quiz" note above
  the form so the client knows why the selection is prefilled.

  Rendered server-side at request time. Astro's static output still works
  because the component reads Astro.url which is populated at build-time
  for static pages and request-time for server pages. Query params are
  read client-side when the page is static — we handle both.
*/
const urlTier = Astro.url?.searchParams.get('tier') ?? '';
const knownTiers = ['starter', 'professional', 'premium'] as const;
type Tier = typeof knownTiers[number];
const initialTier: Tier | '' = (knownTiers as readonly string[]).includes(urlTier)
  ? (urlTier as Tier)
  : '';

const tierCopy: Record<Tier, { label: string; budget: string; project: string; note: string }> = {
  starter: {
    label: 'Starter Site',
    budget: '1000-3000',           // form value closest to $500-$800
    project: 'new-website',
    note: 'Based on the Starter tier you picked — 1–3 pages, clean + fast, $500–$800.',
  },
  professional: {
    label: 'Professional Site',
    budget: '1000-3000',
    project: 'new-website',
    note: 'Based on the Professional tier you picked — 5–10 pages, blog, custom design, $1,200–$2,500.',
  },
  premium: {
    label: 'Premium / E-Commerce',
    budget: '3000-6000',
    project: 'ecommerce',
    note: 'Based on the Premium tier you picked — custom builds, e-commerce, 90-day support, $3,000–$6,000+.',
  },
};

const tierConfig = initialTier ? tierCopy[initialTier] : null;
---

<PageLayout
  title="Contact"
  description={`Get in touch with ${site.name}. We respond ${site.responseTime}.`}
>
  <section class="contact-sec">
    <div class="container">
      <div class="contact-head">
        <span class="section-label">[ i ] / get in touch</span>
        <h1 class="contact-title">Let's build something <em class="serif-accent">that works.</em></h1>
        <p class="contact-lead">
          Tell us about your project below. We respond <strong>{site.responseTime}</strong> — usually much faster.
        </p>

        <div class="contact-badges" role="list">
          <span class="contact-badge" role="listitem">
            <span class="badge-dot"></span>
            Typically replies in under 4 hours
          </span>
          <span class="contact-badge" role="listitem">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Form is encrypted + spam-filtered
          </span>
        </div>
      </div>

      <div class="contact-grid">
        <div class="contact-form-wrap">
          {tierConfig && (
            <div
              class="tier-banner"
              role="note"
              data-tier-banner
              data-initial-tier={initialTier}
            >
              <span class="tier-banner-kicker">Recommended</span>
              <div>
                <strong>{tierConfig.label}</strong>
                <p>{tierConfig.note}</p>
              </div>
            </div>
          )}
          <form
            id="contact-form"
            action={`https://formspree.io/f/${formspree_id}`}
            method="POST"
            novalidate
          >
            <!-- Honeypot: humans never fill this, bots do -->
            <input type="text" name="_gotcha" style="display:none !important" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_subject" value={`New contact from ${site.name} website${initialTier ? ` (${tierCopy[initialTier as Tier].label})` : ''}`} />
            <input type="hidden" name="inferred_tier" value={initialTier} />

            <div class="form-row">
              <label for="name">
                Name <span aria-label="required">*</span>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </label>

              <label for="email">
                Email <span aria-label="required">*</span>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </label>
            </div>

            <div class="form-row">
              <label for="phone">
                Phone
                <input type="tel" id="phone" name="phone" autocomplete="tel" />
              </label>

              <label for="business">
                Business
                <input type="text" id="business" name="business" autocomplete="organization" />
              </label>
            </div>

            <label for="project-type">
              Project type
              <select id="project-type" name="project_type">
                <option value="" selected={!tierConfig}>Select one —</option>
                <option value="new-website" selected={tierConfig?.project === 'new-website'}>New website build</option>
                <option value="redesign">Redesign of existing site</option>
                <option value="ecommerce" selected={tierConfig?.project === 'ecommerce'}>E-commerce / Shopify</option>
                <option value="maintenance">Ongoing maintenance</option>
                <option value="seo">SEO / optimization</option>
                <option value="other">Something else</option>
              </select>
            </label>

            <label for="budget">
              Budget range
              <select id="budget" name="budget">
                <option value="" selected={!tierConfig}>Select one —</option>
                <option value="under-1000">Under $1,000</option>
                <option value="1000-3000" selected={tierConfig?.budget === '1000-3000'}>$1,000 – $3,000</option>
                <option value="3000-6000" selected={tierConfig?.budget === '3000-6000'}>$3,000 – $6,000</option>
                <option value="6000-plus">$6,000+</option>
                <option value="not-sure">Not sure yet</option>
              </select>
            </label>

            <label for="message">
              Tell me about your project <span aria-label="required">*</span>
              <textarea id="message" name="message" rows="6" required placeholder="What's the goal? Who's your audience? Any examples of sites you like?"></textarea>
            </label>

            <div class="form-status" id="form-status" role="status" aria-live="polite"></div>

            <button type="submit" class="btn-primary btn-glow" id="form-submit">
              Send Message
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>

            <p class="form-disclaimer">
              🔒 Submissions go directly to <strong>drake@obsidianwebco.com</strong> via encrypted Formspree. Never sold, never shared, never spammed. By submitting, you agree to our <a href="/privacy">Privacy Policy</a>.
            </p>
          </form>
        </div>

        <aside class="contact-aside">
          <div class="contact-card contact-card--booking">
            <h3>Book a Call</h3>
            <p class="booking-lead">Skip the back-and-forth — grab a <strong>30-min discovery call</strong> on the calendar below. Google Meet link generated automatically.</p>
            <a
              href={site.calendly}
              target="_blank"
              rel="noopener"
              class="btn-primary btn-primary--compact"
            >
              See Available Times
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <p class="booking-fine">Mon–Fri, 10am–4pm ET. 24-hour minimum notice.</p>
          </div>

          <div class="contact-card">
            <h3>Direct</h3>
            <p>Prefer email? Reach us at:</p>
            <a href={`mailto:${site.email}`} class="contact-link">{site.email}</a>
            {site.phone && (
              <>
                <p style="margin-top: 1.25rem;">Or by phone:</p>
                <a href={`tel:${site.phone}`} class="contact-link">{site.phone}</a>
              </>
            )}
          </div>

          <div class="contact-card">
            <h3>Response Time</h3>
            <p>We respond to every inquiry <strong style="color: var(--text);">within 24 hours</strong> — usually much faster. If you don't hear back, check your spam folder before reaching out again.</p>
          </div>

          <div class="contact-card">
            <h3>Based In</h3>
            <p>{site.location.city}, {site.location.state}</p>
            <p style="font-size: 0.875rem; color: var(--muted); margin-top: 0.5rem;">
              Working with clients across Virginia and beyond.
            </p>
          </div>

          <figure class="contact-card contact-card--map">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d410167.7!2d-79.3!3d37.4!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89b3d00cd4af7a27%3A0x8146b3f748c7b7e0!2sLynchburg%2C%20VA!5e0!3m2!1sen!2sus!4v1700000000000"
              width="100%"
              height="240"
              style="border:0; border-radius: var(--radius);"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Map of Lynchburg, VA showing Obsidian Web Co. service area"
            ></iframe>
            <figcaption class="sr-only">Map of Lynchburg, Virginia — Obsidian Web Co.'s service area. We work with clients across Central Virginia and remotely nationwide.</figcaption>
          </figure>
        </aside>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLElement | null;
  const submit = document.getElementById('form-submit') as HTMLButtonElement | null;

  if (form && status && submit) {
    let last_submit = 0;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Client-side rate limit: block submissions within 10s of each other
      const now = Date.now();
      if (now - last_submit < 10_000) {
        status.textContent = 'Please wait a moment before submitting again.';
        status.className = 'form-status form-status--warn';
        return;
      }
      last_submit = now;

      submit.disabled = true;
      submit.style.opacity = '0.6';
      status.textContent = 'Sending…';
      status.className = 'form-status form-status--pending';

      const data = new FormData(form);

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          status.textContent = "✓ Thanks! We got your message and will reply within 24 hours.";
          status.className = 'form-status form-status--success';
          form.reset();
        } else {
          const json = await res.json().catch(() => ({}));
          const msg = json?.errors?.[0]?.message || 'Something went wrong. Please try emailing us directly.';
          status.textContent = msg;
          status.className = 'form-status form-status--error';
        }
      } catch {
        status.textContent = 'Network error. Please try emailing us directly.';
        status.className = 'form-status form-status--error';
      } finally {
        setTimeout(() => {
          submit.disabled = false;
          submit.style.opacity = '1';
        }, 2000);
      }
    });
  }
</script>

<style>
  .contact-sec { padding: 8rem 0 5rem; }

  .contact-head {
    max-width: 900px;
    margin-bottom: 3.5rem;
  }

  .contact-title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0.75rem 0 1.25rem;
  }

  .contact-lead {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 640px;
  }

  .contact-lead strong {
    color: var(--text);
    font-weight: 500;
  }

  /* Response-time + encryption trust badges below the lead copy.
     Pulse dot on the first badge signals live/accepting; lock icon
     on the second signals data security. */
  .contact-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    margin-top: 1.5rem;
  }
  .contact-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    background: rgba(233, 162, 70, 0.06);
    border: 1px solid rgba(233, 162, 70, 0.25);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--ember);
  }
  .badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 8px #4ade80;
    animation: badge-pulse 2s ease-in-out infinite;
  }
  @keyframes badge-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* Tier banner — renders only when the URL has ?tier=starter|professional|premium
     (e.g. coming from /quiz or a vertical landing page CTA). Prefills the form. */
  .tier-banner {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 2px solid var(--ember);
    border-radius: var(--radius);
  }
  .tier-banner-kicker {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ember);
    padding-top: 0.3rem;
    white-space: nowrap;
  }
  .tier-banner strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--text);
    margin-bottom: 0.25rem;
  }
  .tier-banner p {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--muted);
  }

  #contact-form {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; gap: 1.25rem; } }

  #contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 500;
    color: var(--muted);
  }

  #contact-form label span[aria-label="required"] {
    color: var(--flame);
  }

  #contact-form input,
  #contact-form select,
  #contact-form textarea {
    padding: 0.85rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    letter-spacing: normal;
    text-transform: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  #contact-form input:focus,
  #contact-form select:focus,
  #contact-form textarea:focus {
    outline: none;
    border-color: var(--ember);
    box-shadow: 0 0 0 3px rgba(233, 162, 70, 0.15);
  }

  #contact-form textarea {
    resize: vertical;
    min-height: 120px;
    font-family: var(--font-body);
  }

  #form-submit {
    margin-top: 0.5rem;
    justify-self: flex-start;
  }

  .form-disclaimer {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
    text-align: center;
  }

  .form-disclaimer a { color: var(--ember); }

  .form-status {
    padding: 0.875rem 1rem;
    border-radius: var(--radius);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    display: none;
  }

  .form-status--pending,
  .form-status--success,
  .form-status--error,
  .form-status--warn {
    display: block;
  }

  .form-status--success {
    background: rgba(61, 107, 92, 0.18);
    border: 1px solid rgba(61, 107, 92, 0.5);
    color: var(--color-success);
  }

  .form-status--error {
    background: rgba(219, 58, 52, 0.12);
    border: 1px solid rgba(219, 58, 52, 0.45);
    color: var(--color-error);
  }

  .form-status--warn {
    background: rgba(233, 162, 70, 0.12);
    border: 1px solid rgba(233, 162, 70, 0.45);
    color: var(--color-warning);
  }

  .form-status--pending {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
  }

  .contact-card--map { padding: 0.35rem; }

  /* Booking card — elevated treatment since it's the primary CTA in the aside */
  .contact-card--booking {
    border-color: var(--ember);
    background: linear-gradient(180deg, rgba(233, 162, 70, 0.06), var(--surface) 70%);
  }
  .contact-card--booking h3 { color: var(--ember); }
  .booking-lead {
    color: var(--muted) !important;
    font-size: 0.95rem !important;
    line-height: 1.6;
    margin-bottom: 1rem !important;
  }
  .booking-lead strong { color: var(--text); }
  .btn-primary--compact {
    padding: 0.7rem 1.25rem !important;
    font-size: 0.9rem !important;
    width: 100%;
    justify-content: center;
  }
  .booking-fine {
    margin-top: 1rem !important;
    font-family: var(--font-mono);
    font-size: 0.72rem !important;
    letter-spacing: 0.08em;
    color: var(--muted-2) !important;
    text-transform: uppercase;
  }

  .contact-card h3 {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ember);
    margin-bottom: 0.85rem;
  }

  .contact-card p {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0;
    line-height: 1.6;
  }

  .contact-card p strong {
    color: var(--text);
    font-weight: 500;
  }

  .contact-link {
    display: block;
    margin-top: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--ember);
    word-break: break-all;
    letter-spacing: -0.01em;
  }

  .contact-link:hover { color: var(--text); }
</style>
