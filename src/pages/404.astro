---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found" description="We couldn't find that page.">
  <section style="min-height: 70vh; display: flex; align-items: center;">
    <div class="container" style="text-align: center; max-width: 600px;">
      <div class="diamond-divider" aria-hidden="true"><span></span></div>
      <div class="section-label">404</div>
      <h1 style="margin: 1rem 0;">Page Not Found</h1>
      <p style="margin-bottom: 2rem; color: var(--muted);">
        We couldn’t find what you were looking for. Let’s get you back on track.
      </p>
      <a href="/" class="btn-primary btn-glow">Back to Home</a>
    </div>
  </section>
</PageLayout>
