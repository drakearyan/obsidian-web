---
export const prerender = true;
import PageLayout from '../layouts/PageLayout.astro';
import WorldScrollSection from '../components/WorldScrollSection.astro';
import Hero from '../components/Hero.astro';
import StatsBar from '../components/StatsBar.astro';
import ServicesAccordion from '../components/ServicesAccordion.astro';
import ClientLogoGrid from '../components/ClientLogoGrid.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Testimonials from '../components/Testimonials.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import { site } from '../data/site';
import { faqs } from '../data/faq';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<PageLayout
  title={`${site.tagline}`}
  description={site.description}
  jsonLd={[faqSchema]}
>
  <WorldScrollSection />
  <Hero
    title="Websites built"
    titleAccent="to outwork you."
    subtitle="A boutique web design studio for small businesses in Lynchburg and beyond. Custom designed. Fast to ship. Built to convert. Owned by you."
  />
  <StatsBar />
  <ServicesAccordion />
  <ClientLogoGrid />
  <PortfolioPreview />
  <Testimonials />
  <ProcessSteps />
  <FAQ />
  <CTASection
    heading="Ready to build something that works?"
    subheading="A free 30-minute discovery call. I'll walk through your business, the project you have in mind, and whether Obsidian is the right fit — and if not, where to look next."
    ctaText="Book a discovery call"
  />
</PageLayout>
