---
import PageLayout from '../layouts/PageLayout.astro';
import AuditForm from '../components/AuditForm.astro';
import { site } from '../data/site';
---

<PageLayout
  title="Free 5-Minute Website Audit"
  description="Tell me your URL. I'll spend 5 minutes on your site and send back a 1-page PDF with the three things costing you customers — free, no pitch."
>
  <section class="audit-hero">
    <div class="container">
      <span class="section-label section-label--centered">[ ▲ ] / free audit</span>

      <h1 class="audit-title">
        The 3 things costing you customers, <em class="serif-accent">delivered in 24 hours.</em>
      </h1>

      <p class="audit-lead">
        You don't need to hire someone to tell you your website has problems.
        You need someone to tell you <em>which</em> problems matter. I'll spend
        5 minutes on your site and send you a 1-page PDF with the top 3 things
        to fix this week — free, no pitch.
      </p>

      <div class="audit-form-wrap">
        <AuditForm variant="hero" ctaLabel="Get My Audit" />
        <p class="audit-fine">
          I'll email within 24 hours with your 1-page PDF. No automated drip sequence, no phone calls unless you ask.
        </p>
      </div>
    </div>
  </section>

  <section class="audit-process">
    <div class="container">
      <div class="process-grid">
        <article class="process-step">
          <span class="step-num">I.</span>
          <h3>You send me a URL</h3>
          <p>One email address, one link to your site. That's the whole form. Takes 15 seconds.</p>
        </article>

        <article class="process-step">
          <span class="step-num">II.</span>
          <h3>I audit it myself</h3>
          <p>Not a bot. I personally run PageSpeed, accessibility, and SEO checks, then look at the actual UX — how a real customer would experience it.</p>
        </article>

        <article class="process-step">
          <span class="step-num">III.</span>
          <h3>You get a 1-page PDF in 24 hrs</h3>
          <p>Three specific problems, ranked by revenue impact. Each with the exact fix — whether it's a 5-minute tweak you do yourself or something deeper.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="audit-fit">
    <div class="container">
      <div class="fit-head">
        <span class="section-label">[ ? ] / is this for you</span>
        <h2 class="fit-title">The audit works best for <em class="serif-accent">certain kinds of sites.</em></h2>
      </div>

      <div class="fit-grid">
        <div class="fit-col">
          <h4 class="fit-heading fit-heading--yes">Send me yours if…</h4>
          <ul>
            <li>You're a small business in Virginia doing $100K–$5M a year</li>
            <li>Your site is older than 2 years and you haven't touched it</li>
            <li>You suspect you're losing customers but can't prove it</li>
            <li>You've been quoted $10K+ and want a second opinion first</li>
            <li>You run a restaurant, shop, service business, or professional practice</li>
          </ul>
        </div>
        <div class="fit-col">
          <h4 class="fit-heading fit-heading--no">Don't bother if…</h4>
          <ul>
            <li>You need me to audit a site I can't access publicly</li>
            <li>You want a 20-page branding strategy (not what this is)</li>
            <li>You're an SEO agency trying to see my process for free</li>
            <li>You want the audit same-day — 24 hours, not faster</li>
            <li>Your site is genuinely fine and you just want validation</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="audit-cta">
    <div class="container">
      <h2 class="cta-title">Still here? <em class="serif-accent">Send me the link.</em></h2>
      <div class="audit-form-wrap audit-form-wrap--compact">
        <AuditForm
          variant="card"
          heading="Your Site, Audited"
          subheading="Drop your URL + email below. 24-hour turnaround, 1-page PDF, zero pitch."
          ctaLabel="Get My Audit"
        />
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .audit-hero {
    padding: calc(var(--nav-height) + 5rem) 0 4rem;
    text-align: center;
  }

  .section-label--centered {
    justify-content: center;
    text-align: center;
  }
  .section-label--centered::before {
    display: inline-block;
  }

  .audit-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.035em;
    max-width: 900px;
    margin: 1rem auto 1.5rem;
    text-wrap: balance;
  }

  .audit-lead {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 620px;
    margin: 0 auto 3rem;
  }

  .audit-lead em {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ember);
  }

  .audit-form-wrap {
    max-width: 620px;
    margin: 0 auto;
  }

  .audit-fine {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--muted-2);
    text-align: center;
  }

  /* Process section */
  .audit-process {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .process-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .process-step {
    border-left: 1px solid var(--border);
    padding-left: 1.5rem;
  }

  .step-num {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 2.5rem;
    color: var(--ember);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .process-step h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .process-step p {
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* Fit section */
  .audit-fit {
    padding: 5rem 0;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .fit-head {
    max-width: 700px;
    margin-bottom: 3rem;
  }

  .fit-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-top: 1rem;
  }

  .fit-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .fit-grid { grid-template-columns: 1fr; }
  }

  .fit-heading {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 1rem;
  }
  .fit-heading--yes { color: var(--ember); }
  .fit-heading--no { color: var(--muted); }

  .fit-col ul {
    list-style: none;
    padding: 0;
  }
  .fit-col li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .fit-col li:last-child { border-bottom: none; }

  /* Bottom CTA */
  .audit-cta {
    padding: 6rem 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 2rem;
  }

  .audit-form-wrap--compact {
    max-width: 560px;
    margin: 0 auto;
  }
</style>
