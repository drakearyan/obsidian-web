---
import '../styles/global.css';
import '../styles/animations.css';
import SEO from '../components/SEO.astro';
import ExitIntentModal from '../components/ExitIntentModal.astro';
import type { SEOProps } from '../utils/seo';

interface Props extends SEOProps {
  jsonLd?: object[];
}

const ga_id = import.meta.env.PUBLIC_GA4_ID;
const clarity_id = import.meta.env.PUBLIC_CLARITY_ID;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0b0907" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Editorial type stack: Instrument Serif (display) + Instrument Sans (body) + JetBrains Mono (meta) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <SEO {...Astro.props} />

    {ga_id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga_id}`}></script>
        <script define:vars={{ ga_id }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', ga_id, { anonymize_ip: true });
        </script>
      </>
    )}

    {clarity_id && (
      <script define:vars={{ clarity_id }}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", clarity_id);
      </script>
    )}
  </head>
  <body class="anim-stagger anim-progress">
    <a href="#main" class="skip-link">Skip to content</a>

    <slot />

    <!-- Exit-intent audit offer. Self-suppresses on /audit* pages
         and on repeat sessions (sessionStorage flag). -->
    <ExitIntentModal />

    <script>
      import '../scripts/animations.ts';
    </script>
  </body>
</html>
