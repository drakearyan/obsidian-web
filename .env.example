# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Google Analytics 4 Measurement ID (safe to expose - designed to be public)
PUBLIC_GA4_ID=

# Microsoft Clarity Project ID (safe to expose)
PUBLIC_CLARITY_ID=

# Formspree Form ID (client-side, but use honeypot for anti-abuse)
PUBLIC_FORMSPREE_ID=

# Google Maps Embed API key (optional, for contact page map)
PUBLIC_MAPS_API_KEY=

# Business contact info
PUBLIC_BUSINESS_EMAIL=drake@obsidianwebco.com
PUBLIC_BUSINESS_PHONE=
